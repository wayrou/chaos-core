{
  "name": "chaos-core",
  "private": true,
  "version": "0.1.7",
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:haven3d-smoke": "node scripts/haven3d-smoke.mjs",
    "test:field-3d-parity-smoke": "node scripts/field-3d-parity-smoke.mjs",
    "test:apron-coop-smoke": "node scripts/apron-coop-smoke.mjs",
    "test:multiplayer-return-smoke": "node scripts/multiplayer-return-smoke.mjs",
    "preview": "vite preview",
    "backend": "cargo run --manifest-path src-tauri/Cargo.toml --bin chaos_backend",
    "backend:check": "cargo check --manifest-path src-tauri/Cargo.toml --bin chaos_backend",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "jszip": "^3.10.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/three": "^0.183.1",
    "playwright": "1.57.0",
    "pngjs": "7.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
