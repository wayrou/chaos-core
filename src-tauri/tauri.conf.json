{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chaos Core",
  "version": "0.1.2",
  "identifier": "chaos-core",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Chaos Core",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGNDc0Nzk4QjM1RUNFRTQKUldUa3psNnptRWRIdjExakcwbjltd1JzaDd0NzRWd1JwVmk2RWN3YVZLVkpkc2x5U0VHcHFydWIK",
      "endpoints": [
        "https://github.com/wayrou/chaos-core/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
