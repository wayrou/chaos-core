JetBrains Mono', monospace);\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  cursor: pointer;\n  border-radius: 4px;\n  transition: all 0.2s ease;\n}\n\n.unit-auto-battle-toggle:hover {\n  box-shadow: 0 0 12px rgba(53, 255, 149, 0.35);\n}\n\n.unit-auto-battle-toggle--active {\n  background: linear-gradient(180deg, rgba(255, 204, 110, 0.18) 0%, rgba(255, 204, 110, 0.28) 100%);\n  border-color: var(--slk-amber);\n  color: var(--slk-amber);\n  box-shadow: 0 0 12px rgba(255, 204, 110, 0.4);\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE RESULT OVERLAY\n   -------------------------------------------------------------------------- */\n\n.battle-result-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(10, 8, 6, 0.9);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 500;\n  animation: overlay-fade-in 0.5s ease;\n}\n\n@keyframes overlay-fade-in {\n  from {\n    opacity: 0;\n  }\n\n  to {\n    opacity: 1;\n  }\n}\n\n.battle-result-overlay--defeat {\n  background: rgba(40, 10, 10, 0.9);\n}\n\n.battle-result-card {\n  background: var(--surface-dark);\n  border: 2px solid var(--bronze);\n  border-radius: 4px;\n  padding: 2rem;\n  text-align: center;\n  min-width: 350px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  box-shadow:\n    0 0 50px rgba(168, 124, 69, 0.3),\n    inset 0 0 30px rgba(0, 0, 0, 0.5);\n  animation: result-card-appear 0.5s ease;\n}\n\n@keyframes result-card-appear {\n  from {\n    opacity: 0;\n    transform: scale(0.9) translateY(20px);\n  }\n\n  to {\n    opacity: 1;\n    transform: scale(1) translateY(0);\n  }\n}\n\n.battle-result-title {\n  font-size: 2rem;\n  font-weight: bold;\n  color: var(--slk-amber);\n  text-transform: uppercase;\n  letter-spacing: 0.2em;\n  margin-bottom: 1.5rem;\n  text-shadow: 0 0 30px rgba(255, 204, 110, 0.5);\n}\n\n.battle-result-overlay--defeat .battle-result-title {\n  color: var(--slk-red);\n  text-shadow: 0 0 30px rgba(255, 107, 107, 0.5);\n}\n\n.battle-defeat-text {\n  color: var(--bronze-light);\n  margin-bottom: 1.5rem;\n  font-size: 0.9rem;\n}\n\n.battle-reward-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0.75rem;\n  margin-bottom: 1.5rem;\n}\n\n.battle-reward-item {\n  background: var(--ardycia-earth-mid);\n  border: 1px solid var(--surface-border);\n  border-radius: 2px;\n  padding: 0.6rem;\n}\n\n.reward-label {\n  font-size: 0.55rem;\n  color: var(--bronze);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-bottom: 0.25rem;\n}\n\n.reward-value {\n  font-size: 1rem;\n  font-weight: bold;\n  color: var(--slk-green);\n  text-shadow: 0 0 10px var(--slk-green-glow);\n}\n\n.battle-result-footer {\n  margin-top: 1rem;\n}\n\n.battle-result-btn {\n  padding: 0.75rem 2rem;\n  background: var(--bronze-dark);\n  border: 2px solid var(--bronze);\n  color: var(--slk-amber);\n  font-family: inherit;\n  font-size: 0.9rem;\n  font-weight: bold;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.battle-result-btn:hover {\n  background: var(--bronze);\n  color: var(--ardycia-earth-dark);\n  box-shadow: 0 0 20px rgba(168, 124, 69, 0.5);\n}\n\n/* --------------------------------------------------------------------------\n   TRAINING COMPLETE SCREEN\n   -------------------------------------------------------------------------- */\n\n.training-complete-screen {\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 2.5rem 1.5rem;\n  background:\n    radial-gradient(ellipse at center, rgba(45, 38, 31, 0.5) 0%, rgba(10, 9, 7, 0.98) 80%),\n    linear-gradient(135deg, rgba(53, 255, 149, 0.05), rgba(255, 204, 110, 0.06));\n  color: var(--bronze-light);\n  font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n  flex-direction: column;\n}\n\n.training-complete-header {\n  text-align: center;\n  margin-bottom: 1.5rem;\n}\n\n.training-complete-title {\n  margin: 0;\n  letter-spacing: 0.24em;\n  font-size: 1.6rem;\n  color: var(--slk-amber);\n  text-shadow:\n    0 0 12px rgba(255, 204, 110, 0.4),\n    0 0 24px rgba(255, 204, 110, 0.2);\n}\n\n.training-complete-subtitle {\n  margin-top: 0.4rem;\n  font-size: 0.9rem;\n  color: var(--bronze);\n  letter-spacing: 0.12em;\n}\n\n.training-complete-content {\n  width: min(720px, 100%);\n  background: rgba(24, 23, 22, 0.92);\n  border: 1px solid rgba(168, 124, 69, 0.35);\n  box-shadow:\n    0 0 25px rgba(0, 0, 0, 0.65),\n    inset 0 0 30px rgba(53, 255, 149, 0.05);\n  border-radius: 6px;\n  padding: 2rem;\n  backdrop-filter: blur(6px);\n}\n\n.training-complete-message {\n  background: linear-gradient(180deg, rgba(77, 63, 52, 0.35) 0%, rgba(45, 38, 31, 0.55) 100%);\n  border: 1px solid rgba(168, 124, 69, 0.35);\n  padding: 1rem 1.25rem;\n  border-radius: 4px;\n  color: var(--ard-off-white);\n  line-height: 1.5;\n}\n\n.training-complete-actions {\n  margin-top: 1.75rem;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 1rem;\n}\n\n.training-action-btn {\n  width: 100%;\n  max-width: 300px;\n  padding: 0.9rem 1rem;\n  background: var(--surface-dark);\n  color: var(--bronze-light);\n  border: 1px solid var(--surface-border);\n  text-transform: uppercase;\n  letter-spacing: 0.14em;\n  font-weight: 700;\n  cursor: pointer;\n  transition: transform 0.12s ease, box-shadow 0.2s ease, border-color 0.2s ease;\n  border-radius: 3px;\n}\n\n.training-action-btn:hover {\n  transform: translateY(-1px);\n  border-color: var(--slk-amber);\n  box-shadow:\n    0 0 12px rgba(255, 204, 110, 0.4),\n    inset 0 0 8px rgba(255, 204, 110, 0.18);\n}\n\n.training-action-btn--primary {\n  background: linear-gradient(180deg, rgba(53, 255, 149, 0.18) 0%, rgba(26, 122, 72, 0.28) 100%);\n  border-color: var(--slk-green);\n  color: var(--slk-green);\n  box-shadow:\n    0 0 12px var(--slk-green-glow),\n    inset 0 0 10px rgba(53, 255, 149, 0.18);\n}\n\n.training-action-btn--primary:hover {\n  box-shadow:\n    0 0 16px var(--slk-green-glow),\n    inset 0 0 14px rgba(53, 255, 149, 0.25);\n}\n\n/* --------------------------------------------------------------------------\n   RESPONSIVE ADJUSTMENTS\n   -------------------------------------------------------------------------- */\n\n@media (max-width: 1200px) {\n  .battle-tile {\n    width: 56px;\n    height: 56px;\n  }\n\n  .battle-cardui {\n    width: 100px;\n    height: 140px;\n  }\n\n  .battle-card-slot {\n    margin-left: -25px;\n  }\n}\n\n@media (max-width: 900px) {\n  .battle-bottom {\n    flex-direction: column;\n    max-height: none;\n  }\n\n  .battle-unit-panel {\n    width: 100%;\n  }\n\n  .battle-tile {\n    width: 48px;\n    height: 48px;\n  }\n\n  /* --------------------------------------------------------------------------\n   BATTLE FEEDBACK - Damage Numbers & Screen Shake\n   -------------------------------------------------------------------------- */\n  .floating-combat-text {\n    position: absolute;\n    pointer-events: none;\n    font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n    font-weight: bold;\n    font-size: 1.2rem;\n    z-index: 1000;\n    text-shadow:\n      0 2px 4px rgba(0, 0, 0, 0.8),\n      0 0 8px rgba(0, 0, 0, 0.6);\n    opacity: 0;\n    transform: translate(-50%, -50%);\n    animation: float-up 1.2s ease-out forwards;\n  }\n\n  .floating-combat-text--damage {\n    color: #ff4444;\n    text-shadow: 0 0 10px rgba(255, 68, 68, 0.6), 0 2px 4px rgba(0, 0, 0, 0.8);\n  }\n\n  .floating-combat-text--heal {\n    color: #44ff44;\n    text-shadow: 0 0 10px rgba(68, 255, 68, 0.6), 0 2px 4px rgba(0, 0, 0, 0.8);\n  }\n\n  .floating-combat-text--crit {\n    font-size: 1.8rem;\n    color: #ffaa00;\n    text-shadow: 0 0 15px rgba(255, 170, 0, 0.8), 0 2px 4px rgba(0, 0, 0, 0.8);\n    animation: float-up-crit 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;\n  }\n\n  @keyframes float-up {\n    0% {\n      opacity: 0;\n      transform: translate(-50%, -20%);\n    }\n\n    15% {\n      opacity: 1;\n      transform: translate(-50%, -50%);\n    }\n\n    80% {\n      opacity: 1;\n      transform: translate(-50%, -100%);\n    }\n\n    100% {\n      opacity: 0;\n      transform: translate(-50%, -120%);\n    }\n  }\n\n  @keyframes float-up-crit {\n    0% {\n      opacity: 0;\n      transform: translate(-50%, -20%) scale(0.5);\n    }\n\n    15% {\n      opacity: 1;\n      transform: translate(-50%, -50%) scale(1.2);\n    }\n\n    30% {\n      transform: translate(-50%, -60%) scale(1);\n    }\n\n    80% {\n      opacity: 1;\n      transform: translate(-50%, -100%) scale(1);\n    }\n\n    100% {\n      opacity: 0;\n      transform: translate(-50%, -120%) scale(0.8);\n    }\n  }\n\n  .screen-shake {\n    animation: shake 0.4s cubic-bezier(.36, .07, .19, .97) both;\n  }\n\n  @keyframes shake {\n\n    10%,\n    90% {\n      transform: translate3d(-2px, 0, 0);\n    }\n\n    20%,\n    80% {\n      transform: translate3d(4px, 0, 0);\n    }\n\n    30%,\n    50%,\n    70% {\n      transform: translate3d(-8px, 0, 0);\n    }\n\n    40%,\n    60% {\n      transform: translate3d(8px, 0, 0);\n    }\n  }\n}\n\n/* ==========================================================================\n   CHAOS CORE - CRAFTING SCREEN STYLES\n   Ardycia Aesthetic: Utilitycore + S/COM_OS Terminal\n   ========================================================================== */\n\n/* --------------------------------------------------------------------------\n   CRAFTING ROOT\n   -------------------------------------------------------------------------- */\n\n.crafting-root {\n  height: 100vh !important;\n  max-height: 100vh !important;\n  overflow: hidden !important;\n  padding: 0.75rem !important;\n  /* Override styles.css padding */\n  background:\n    url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='