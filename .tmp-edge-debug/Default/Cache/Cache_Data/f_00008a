\n  width: 100%;\n  font-size: 10px;\n  padding: 6px 12px;\n  border-radius: 6px;\n  border: 1px solid rgba(155, 127, 255, 0.5);\n  background: rgba(60, 40, 100, 0.5);\n  color: #c5a3ff;\n  cursor: pointer;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  transition: all 0.12s ease-out;\n}\n\n.hardpoint-slot-btn:hover {\n  background: rgba(90, 60, 140, 0.6);\n  border-color: #9b7fff;\n}\n\n.hardpoints-inventory {\n  margin-top: 16px;\n}\n\n.hardpoints-inventory-title {\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  margin-bottom: 10px;\n  color: rgba(200, 180, 255, 0.8);\n  padding-bottom: 6px;\n  border-bottom: 1px solid rgba(140, 160, 255, 0.15);\n}\n\n.hardpoints-inventory-list {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  max-height: 40vh;\n  overflow-y: auto;\n  padding-right: 4px;\n}\n\n.hardpoint-mod-item {\n  background: rgba(15, 18, 45, 0.6);\n  border: 1px solid rgba(100, 120, 200, 0.25);\n  border-radius: 8px;\n  padding: 10px;\n  cursor: pointer;\n  transition: all 0.15s ease;\n  position: relative;\n}\n\n.hardpoint-mod-item:hover:not(.hardpoint-mod-item--slotted) {\n  border-color: rgba(155, 127, 255, 0.5);\n  background: rgba(25, 30, 65, 0.7);\n  transform: translateX(2px);\n}\n\n.hardpoint-mod-item--slotted {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.hardpoint-mod-name {\n  font-size: 12px;\n  font-weight: 600;\n  margin-bottom: 4px;\n  color: #d4dcff;\n}\n\n.hardpoint-mod-rarity {\n  font-size: 8px;\n  padding: 2px 6px;\n  border-radius: 4px;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  display: inline-block;\n  margin-bottom: 6px;\n}\n\n.hardpoint-mod-rarity--common {\n  background: rgba(100, 120, 180, 0.3);\n  border: 1px solid rgba(100, 120, 180, 0.5);\n  color: #a0b4ff;\n}\n\n.hardpoint-mod-rarity--uncommon {\n  background: rgba(74, 222, 128, 0.2);\n  border: 1px solid rgba(74, 222, 128, 0.4);\n  color: #4ade80;\n}\n\n.hardpoint-mod-rarity--rare {\n  background: rgba(168, 85, 247, 0.2);\n  border: 1px solid rgba(168, 85, 247, 0.4);\n  color: #a855f7;\n}\n\n.hardpoint-mod-description {\n  font-size: 10px;\n  opacity: 0.75;\n  line-height: 1.4;\n  color: #c8d4ff;\n}\n\n.hardpoint-mod-stacks {\n  font-size: 9px;\n  opacity: 0.6;\n  color: #b8c4ff;\n  font-weight: 600;\n  margin-top: 4px;\n}\n\n.hardpoint-mod-badge {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  font-size: 8px;\n  padding: 2px 6px;\n  background: rgba(74, 222, 128, 0.3);\n  border: 1px solid rgba(74, 222, 128, 0.5);\n  border-radius: 4px;\n  color: #4ade80;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n}\n\n.hardpoints-empty-message,\n.hardpoints-empty-inventory {\n  font-size: 11px;\n  opacity: 0.6;\n  font-style: italic;\n  color: rgba(200, 200, 220, 0.7);\n  padding: 12px;\n  text-align: center;\n}\n\n/* Equipment Modal */\n\n.equip-modal {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.8);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n}\n\n.equip-modal-content {\n  width: 100%;\n  max-width: 500px;\n  max-height: 80vh;\n  background: linear-gradient(145deg,\n      rgba(15, 18, 45, 0.98),\n      rgba(25, 30, 65, 0.98));\n  border: 1px solid rgba(140, 160, 255, 0.5);\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);\n}\n\n.equip-modal-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 14px 18px;\n  border-bottom: 1px solid rgba(140, 160, 255, 0.2);\n  background: rgba(25, 30, 70, 0.5);\n}\n\n.equip-modal-title {\n  font-size: 14px;\n  font-weight: 600;\n  letter-spacing: 0.12em;\n}\n\n.equip-modal-close {\n  font-size: 20px;\n  width: 28px;\n  height: 28px;\n  border: none;\n  background: rgba(255, 100, 120, 0.2);\n  color: #ffb8c4;\n  border-radius: 6px;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.equip-modal-close:hover {\n  background: rgba(255, 100, 120, 0.4);\n}\n\n.equip-modal-body {\n  padding: 16px;\n  max-height: 60vh;\n  overflow-y: auto;\n}\n\n.equip-modal-slot-label {\n  font-size: 11px;\n  opacity: 0.7;\n  margin-bottom: 12px;\n  letter-spacing: 0.08em;\n}\n\n.equip-modal-empty {\n  text-align: center;\n  padding: 40px 20px;\n  opacity: 0.6;\n  font-style: italic;\n}\n\n.equip-options-list {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n\n.equip-option {\n  background: rgba(20, 25, 55, 0.7);\n  border: 1px solid rgba(100, 120, 200, 0.35);\n  border-radius: 8px;\n  padding: 12px;\n  cursor: pointer;\n  transition: all 0.12s ease-out;\n  position: relative;\n}\n\n.equip-option:hover {\n  background: rgba(40, 50, 90, 0.7);\n  border-color: rgba(150, 170, 255, 0.6);\n}\n\n.equip-option--current {\n  border-color: rgba(100, 255, 150, 0.5);\n  background: rgba(20, 45, 35, 0.7);\n}\n\n.equip-option-name {\n  font-size: 14px;\n  font-weight: 600;\n  margin-bottom: 4px;\n}\n\n.equip-option-stats {\n  font-size: 11px;\n  opacity: 0.75;\n  margin-bottom: 2px;\n}\n\n.equip-option-cards {\n  font-size: 10px;\n  opacity: 0.6;\n}\n\n.equip-option-badge {\n  position: absolute;\n  top: 10px;\n  right: 10px;\n  font-size: 9px;\n  padding: 2px 8px;\n  background: rgba(100, 255, 150, 0.2);\n  border: 1px solid rgba(100, 255, 150, 0.5);\n  border-radius: 999px;\n  color: #9fffb8;\n  letter-spacing: 0.1em;\n}\n\n/* ===========================\n   WEAPON DETAIL MODAL\n   =========================== */\n\n.weapon-detail-modal {\n  position: fixed;\n  inset: 0;\n  background: rgba(0, 0, 0, 0.85);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1001;\n}\n\n.weapon-detail-modal-content {\n  width: 100%;\n  max-width: 600px;\n  max-height: 85vh;\n  background: linear-gradient(145deg,\n      rgba(15, 18, 45, 0.98),\n      rgba(25, 30, 65, 0.98));\n  border: 2px solid var(--ard-gold);\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.9);\n}\n\n.weapon-detail-modal-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 16px 20px;\n  border-bottom: 1px solid var(--ard-gold);\n  background: rgba(25, 30, 70, 0.6);\n}\n\n.weapon-detail-modal-title {\n  font-size: 15px;\n  font-weight: 700;\n  letter-spacing: 0.15em;\n  color: var(--ard-gold);\n}\n\n.weapon-detail-modal-close {\n  font-size: 22px;\n  width: 32px;\n  height: 32px;\n  border: none;\n  background: rgba(255, 100, 120, 0.2);\n  color: #ffb8c4;\n  border-radius: 6px;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: all 0.2s;\n}\n\n.weapon-detail-modal-close:hover {\n  background: rgba(255, 100, 120, 0.5);\n  transform: scale(1.1);\n}\n\n.weapon-detail-modal-body {\n  padding: 20px;\n  max-height: 70vh;\n  overflow-y: auto;\n}\n\n.weapon-detail-content {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.weapon-detail-header-section {\n  text-align: center;\n  padding-bottom: 12px;\n  border-bottom: 1px solid rgba(140, 160, 255, 0.2);\n}\n\n.weapon-detail-name {\n  font-size: 20px;\n  font-weight: 700;\n  letter-spacing: 0.1em;\n  color: var(--ard-gold);\n  margin-bottom: 4px;\n}\n\n.weapon-detail-type {\n  font-size: 11px;\n  letter-spacing: 0.15em;\n  opacity: 0.7;\n  color: var(--ard-brown-mid);\n}\n\n.weapon-detail-stats {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 8px;\n  padding: 12px;\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(140, 160, 255, 0.2);\n  border-radius: 8px;\n}\n\n.weapon-detail-stat-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 13px;\n}\n\n.weapon-detail-stat-label {\n  font-weight: 600;\n  opacity: 0.8;\n  letter-spacing: 0.08em;\n}\n\n.weapon-detail-stat-value {\n  font-weight: 700;\n  color: var(--ard-gold);\n}\n\n.weapon-detail-section {\n  padding: 12px;\n  background: rgba(0, 0, 0, 0.15);\n  border: 1px solid rgba(140, 160, 255, 0.15);\n  border-radius: 8px;\n}\n\n.weapon-detail-section-title {\n  font-size: 12px;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  color: var(--ard-gold);\n  margin-bottom: 10px;\n  padding-bottom: 6px;\n  border-bottom: 1px solid rgba(243, 163, 16, 0.3);\n}\n\n.weapon-detail-section-subtitle {\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 0.1em;\n  opacity: 0.8;\n  margin-top: 12px;\n  margin-bottom: 8px;\n}\n\n.weapon-detail-cards {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.weapon-detail-card-name {\n  font-size: 12px;\n  padding: 4px 8px;\n  background: rgba(140, 160, 255, 0.1);\n  border-radius: 4px;\n}\n\n.weapon-detail-clutch {\n  font-size: 12px;\n  padding: 8px;\n  background: rgba(74, 222, 128, 0.1);\n  border: 1px solid rgba(74, 222, 128, 0.3);\n  border-radius: 6px;\n  color: #9fffb8;\n}\n\n.weapon-detail-heat-info,\n.weapon-detail-ammo-info {\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n  margin-bottom: 12px;\n}\n\n.weapon-detail-heat-row {\n  display: flex;\n  justify-content: space-between;\n  font-size: 12px;\n  padding: 4px 0;\n}\n\n.weapon-detail-heat-zones {\n  margin-top: 8px;\n}\n\n.weapon-detail-heat-zone {\n  padding: 8px;\n  margin-bottom: 6px;\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(140, 160, 255, 0.2);\n  border-radius: 6px;\n}\n\n.weapon-detail-heat-zone-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 4px;\n}\n\n.weapon-detail-heat-zone-range {\n  font-size: 13px;\n  font-weight: 700;\n  color: var(--ard-gold);\n}\n\n.weapon-detail-heat-zone-name {\n  font-size: 12px;\n  font-weight: 600;\n  letter-spacing: 0.08em;\n}\n\n.weapon-detail-heat-zone-effect {\n  font-size: 11px;\n  padding: 4px 8px;\n  background: rgba(239, 68, 68, 0.15);\n  border-left: 3px solid #ef4444;\n  color: #ffb8b8;\n  border-radius: 3px;\n  margin-top: 4px;\n}\n\n.weapon-detail-heat-zone