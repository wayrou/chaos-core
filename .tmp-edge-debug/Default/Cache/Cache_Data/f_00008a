adow 0.15s ease, border-color 0.15s ease;\n}\n\n.opmap-node-advance-btn:hover {\n  transform: translateX(-50%) translateY(-1px);\n  border-color: rgba(209, 180, 255, 0.95);\n  box-shadow: 0 14px 28px rgba(32, 16, 56, 0.55), 0 0 22px rgba(188, 149, 255, 0.4);\n}\n\n.opmap-node-advance-btn__label {\n  display: block;\n  white-space: nowrap;\n}\n\n/* Connection/Edge styling */\n\n.opmap-connection {\n  position: absolute;\n  pointer-events: none;\n  z-index: 1;\n}\n\n.opmap-connection--cleared-route {\n  filter: drop-shadow(0 0 4px rgba(243, 163, 16, 0.6));\n}\n\n.opmap-connection--branch-choice {\n  filter: drop-shadow(0 0 4px rgba(235, 156, 101, 0.6));\n  animation: pulse-connection 2s ease-in-out infinite;\n}\n\n@keyframes pulse-connection {\n\n  0%,\n  100% {\n    opacity: 0.9;\n  }\n\n  50% {\n    opacity: 1;\n  }\n}\n\n.opmap-connection--glow {\n  filter: drop-shadow(0 0 8px rgba(100, 255, 100, 0.8));\n  animation: glow-pulse 1.5s ease-in-out infinite;\n}\n\n@keyframes glow-pulse {\n\n  0%,\n  100% {\n    opacity: 0.6;\n  }\n\n  50% {\n    opacity: 1;\n  }\n}\n\n/* Context Panel - Ardycia style */\n\n.opmap-context-panel {\n  position: fixed;\n  top: var(--space-4, 1rem);\n  left: var(--space-4, 1rem);\n  width: 360px;\n  max-width: calc(100vw - var(--space-8, 2rem));\n  background: var(--bg-panel, #4d3f34);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n  z-index: 100;\n  pointer-events: auto;\n  max-height: calc(100vh - var(--space-8, 2rem));\n  overflow-y: auto;\n}\n\n.opmap-context-header {\n  padding: var(--space-3, 0.75rem) var(--space-4, 1rem);\n  background: var(--bg-panel-alt, #3b2f24);\n  border-bottom: var(--stroke-1, 1px) solid var(--stroke-panel, #7a5a32);\n  cursor: grab;\n  user-select: none;\n}\n\n.opmap-context-header:active {\n  cursor: grabbing;\n}\n\n.opmap-context-resize {\n  position: absolute;\n  right: 0.2rem