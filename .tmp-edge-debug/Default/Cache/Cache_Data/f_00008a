ant;\n  border-radius: 4px !important;\n  cursor: pointer !important;\n}\n\n.unitdetail-back-btn:hover {\n  background: var(--ard-brown-dark) !important;\n  border-color: var(--ard-rust) !important;\n  color: var(--ard-off-white) !important;\n}\n\n/* Equipment Slots */\n\n.equip-slot {\n  background: rgba(0, 0, 0, 0.3) !important;\n  border: 1px solid rgba(128, 109, 78, 0.3) !important;\n  border-radius: 4px !important;\n  padding: 0.75rem !important;\n  margin-bottom: 0.5rem !important;\n}\n\n.equip-slot:hover {\n  border-color: var(--ard-brown-mid) !important;\n}\n\n.equip-slot-header {\n  color: var(--ard-gold) !important;\n  font-size: 0.7rem !important;\n  text-transform: uppercase !important;\n  margin-bottom: 0.5rem !important;\n}\n\n.equip-slot-name {\n  color: var(--ard-off-white) !important;\n  font-weight: 500 !important;\n}\n\n.equip-slot-stats {\n  color: var(--ard-sage) !important;\n  font-size: 0.75rem !important;\n}\n\n.equip-slot-cards {\n  color: var(--ard-amber) !important;\n  font-size: 0.7rem !important;\n}\n\n.equip-btn {\n  background: var(--ard-charcoal) !important;\n  border: 1px solid var(--ard-brown-mid) !important;\n  color: var(--ard-sage) !important;\n  padding: 0.35rem 0.75rem !important;\n  border-radius: 3px !important;\n  font-size: 0.65rem !important;\n  cursor: pointer !important;\n}\n\n.equip-btn:hover {\n  background: var(--ard-rust) !important;\n  border-color: var(--ard-gold) !important;\n  color: var(--ard-off-white) !important;\n}\n\n/* Deck Cards */\n\n.deck-card {\n  background: rgba(0, 0, 0, 0.3) !important;\n  border: 1px solid rgba(128, 109, 78, 0.3) !important;\n  border-radius: 4px !important;\n  padding: 0.5rem !important;\n}\n\n.deck-card-header {\n  color: var(--ard-off-white) !important;\n  font-weight: 500 !important;\n}\n\n.deck-card-type {\n  color: var(--ard-cool-gray) !important;\n  font-size: 0.65rem !important;\n  text-transform: uppercase !important;\n}\n\n.deck-card-desc {\n  color: var(--ard-sage) !impor