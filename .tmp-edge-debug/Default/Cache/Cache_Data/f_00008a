ackground: rgba(70, 90, 160, 0.6);\n  border-color: #a8c0ff;\n}\n\n/* Deck Display */\n\n.unitdetail-deck-info {\n  font-size: 11px;\n  opacity: 0.6;\n  margin-bottom: 12px;\n  font-style: italic;\n}\n\n.deck-grid,\n.deck-cards-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));\n  gap: 10px;\n  max-height: 55vh;\n  overflow-y: auto;\n  padding-right: 4px;\n}\n\n.deck-card {\n  background: radial-gradient(circle at top,\n      rgba(30, 35, 70, 0.9),\n      rgba(15, 18, 40, 0.95));\n  border: 1px solid rgba(120, 140, 220, 0.4);\n  border-radius: 8px;\n  padding: 10px;\n  position: relative;\n}\n\n.deck-card--core {\n  border-color: rgba(180, 180, 200, 0.5);\n}\n\n.deck-card--class {\n  border-color: rgba(255, 200, 100, 0.5);\n  background: radial-gradient(circle at top,\n      rgba(50, 40, 30, 0.9),\n      rgba(25, 20, 15, 0.95));\n}\n\n.deck-card--equipment {\n  border-color: rgba(100, 200, 255, 0.5);\n  background: radial-gradient(circle at top,\n      rgba(25, 40, 55, 0.9),\n      rgba(12, 20, 28, 0.95));\n}\n\n.deck-card--gambit {\n  border-color: rgba(255, 100, 150, 0.5);\n  background: radial-gradient(circle at top,\n      rgba(55, 25, 35, 0.9),\n      rgba(28, 12, 18, 0.95));\n}\n\n.deck-card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 4px;\n}\n\n.deck-card-name {\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 0.04em;\n}\n\n.deck-card-cost {\n  font-size: 10px;\n  padding: 2px 6px;\n  background: rgba(10, 12, 30, 0.8);\n  border: 1px solid rgba(160, 180, 255, 0.5);\n  border-radius: 999px;\n}\n\n.deck-card-type {\n  font-size: 8px;\n  letter-spacing: 0.14em;\n  opacity: 0.55;\n  margin-bottom: 6px;\n}\n\n.deck-card-desc {\n  font-size: 10px;\n  line-height: 1.35;\n  opacity: 0.8;\n}\n\n.deck-card-count {\n  position: absolute;\n  top: 6px;\n  right: 6px;\n  font-size: 10px;\n  font-weight: 600;\n  padding: 2px 6px;\n  background: rgba(100, 120, 200, 0