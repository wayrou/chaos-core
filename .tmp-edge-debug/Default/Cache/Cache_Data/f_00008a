00);\n  color: var(--ink-accent, #ffcc6e);\n  line-height: 1;\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n}\n\n.opmap-floor-total {\n  font-size: var(--text-sm, 0.75rem);\n  color: var(--ink-secondary, #a8a8a5);\n  margin-top: var(--space-1, 0.25rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n}\n\n/* Nodes container - absolute positioning for branching layout */\n\n/* ============================================================================\n   OPERATION MAP SCREEN - Missing CSS Classes\n   ============================================================================ */\n\n/* Nodes container - absolute positioning for branching layout */\n\n.opmap-nodes-container {\n  position: relative;\n  width: 100%;\n  height: 100%;\n  min-width: 2000px;\n  min-height: 1500px;\n}\n\n/* Node wrapper for positioning */\n\n.opmap-node-wrapper {\n  position: absolute;\n  z-index: 10;\n  pointer-events: auto;\n}\n\n/* Node styling - Ardycia style */\n\n.opmap-node {\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-1, 0.25rem);\n  cursor: pointer;\n  transition: all var(--transition-base, 0.15s ease);\n  padding: var(--space-2, 0.5rem);\n  border-radius: var(--radius-sm, 3px);\n  /* Removed transform: translate from here as it's handled by opmap-node-wrapper */\n}\n\n.opmap-node:hover {\n  z-index: 20;\n  /* Removed transform: none to prevent jump if translate was set elsewhere */\n}\n\n.opmap-node--current {\n  filter: drop-shadow(0 0 8px var(--ink-accent, #ffcc6e));\n}\n\n.opmap-node--available {\n  filter: drop-shadow(0 0 4px var(--ard-amber, #eb9c65));\n}\n\n.opmap-node--visited {\n  opacity: 0.7;\n}\n\n.opmap-node--locked {\n  opacity: 0.3;\n  cursor: not-allowed;\n}\n\n.opmap-node-shape {\n  width: 48px;\n  height: 48px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--bg-panel, #4d3f34);\n  border: var(--stroke-2, 2px) 