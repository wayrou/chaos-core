);\n  background:\n    linear-gradient(180deg, rgba(255, 204, 110, 0.09), rgba(255, 204, 110, 0.02)),\n    rgba(18, 17, 15, 0.94);\n  color: var(--ink);\n  font-weight: 700;\n  letter-spacing: 0.04em;\n}\n\n.outer-deck-transit-btn--primary,\n.materials-refinery-craft-btn {\n  border-color: rgba(255, 204, 110, 0.4);\n  box-shadow: inset 0 0 0 1px rgba(255, 204, 110, 0.07);\n}\n\n.outer-deck-transit-close:hover,\n.outer-deck-transit-btn:hover,\n.materials-refinery-back-btn:hover,\n.materials-refinery-craft-btn:hover {\n  border-color: var(--tech-amber);\n  box-shadow: var(--shadow-glow-amber);\n}\n\n.outer-deck-transit-btn:disabled,\n.materials-refinery-craft-btn:disabled {\n  opacity: 0.45;\n  cursor: not-allowed;\n  box-shadow: none;\n}\n\n.outer-deck-transit-status,\n.materials-refinery-resource-strip,\n.materials-refinery-footer {\n  border: 1px solid var(--stroke-subtle);\n  border-radius: var(--radius-panel);\n  background:\n    linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 28%),\n    rgba(24, 22, 20, 0.88);\n  box-shadow: var(--shadow-elev-1);\n}\n\n.outer-deck-transit-status,\n.materials-refinery-footer {\n  padding: var(--space-3);\n}\n\n.outer-deck-transit-status-chip,\n.materials-refinery-destination {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.45rem 0.7rem;\n  border: 1px solid rgba(255, 204, 110, 0.18);\n  border-radius: 999px;\n  background: rgba(255, 204, 110, 0.08);\n  color: var(--ink-soft);\n}\n\n.outer-deck-transit-grid,\n.materials-refinery-grid {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.outer-deck-transit-grid {\n  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));\n}\n\n.materials-refinery-grid {\n  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n}\n\n.outer-deck-transit-card,\n.materials-refinery-card {\n  border: 1px solid var(--stroke-subtle);\n  border-radius: var(--radius-panel);\n  padding: clamp(14px, 1.8vw, 20px);\n  background:\n    linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 24%),\n    rgba(24, 22, 20, 0.82);\n  box-shadow: var(--shadow-elev-1);\n  display: flex;\n  flex-direction: column;\n  gap: 0.8rem;\n}\n\n.outer-deck-transit-card--active {\n  border-color: rgba(255, 204, 110, 0.34);\n  box-shadow: var(--shadow-glow-amber);\n}\n\n.outer-deck-transit-card-header,\n.materials-refinery-card-header {\n  display: flex;\n  justify-content: space-between;\n  gap: 1rem;\n  align-items: baseline;\n  flex-wrap: wrap;\n}\n\n.outer-deck-transit-card-kicker,\n.materials-refinery-card-owned {\n  font-size: 0.75rem;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--ink-dim);\n}\n\n.outer-deck-transit-card h2 {\n  margin: 0;\n  font-size: 1rem;\n}\n\n.outer-deck-transit-card-copy,\n.materials-refinery-card-copy {\n  margin: 0;\n  color: var(--ink-soft);\n}\n\n.outer-deck-transit-card-meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5rem;\n}\n\n.outer-deck-transit-card-meta span,\n.materials-refinery-resource-item,\n.materials-refinery-card-cost,\n.materials-refinery-card-status {\n  padding: 0.45rem 0.6rem;\n  border: 1px solid rgba(255, 255, 255, 0.06);\n  border-radius: var(--radius-sm);\n  background: rgba(255, 255, 255, 0.02);\n  color: var(--ink-soft);\n}\n\n.materials-refinery-resource-strip {\n  display: grid;\n  gap: 0.75rem;\n  padding: var(--space-3);\n  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));\n}\n\n.materials-refinery-card-name {\n  font-weight: 800;\n  letter-spacing: 0.05em;\n}\n\n.materials-refinery-card-status--short {\n  color: #f0ae88;\n  border-color: rgba(240, 174, 136, 0.18);\n}\n\n.materials-refinery-card--locked {\n  border-color: rgba(240, 174, 136, 0.14);\n}\n\n/* ==========================================================================\n   EZ DRAG\n   Window dragging affordance for movable UI surfaces\n   ========================================================================== */\n\n.ez-drag-handle {\n  cursor: grab;\n  user-select: none;\n  touch-action: none;\n}\n\n.ez-drag-window {\n  transition: box-shadow 0.15s ease;\n}\n\n.ez-drag-window--dragging {\n  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(255, 204, 110, 0.18);\n}\n\nbody.ez-dragging,\nbody.ez-dragging * {\n  cursor: grabbing !important;\n}\n\n/* ==========================================================================\n   SCROLLBAR STYLING\n   ========================================================================== */\n\n::-webkit-scrollbar {\n  width: 8px;\n  height: 8px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--ard-dark);\n}\n\n::-webkit-scrollbar-thumb {\n  background: var(--ard-brown-mid);\n  border-radius: 4px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: var(--ard-rust);\n}\n\n* {\n  scrollbar-width: thin;\n  scrollbar-color: var(--ard-brown-mid) var(--ard-dark);\n}\n\n/* ==========================================================================\n   RESPONSIVE SCALING\n   ========================================================================== */\n\n@media (max-height: 700px) {\n  :root {\n    --font-size-xs: 0.6rem;\n    --font-size-sm: 0.7rem;\n    --font-size-md: 0.8rem;\n    --font-size-lg: 0.9rem;\n    --spacing-sm: 0.35rem;\n    --spacing-md: 0.5rem;\n  }\n}\n\n@media (max-width: 768px) {\n  .shop-header {\n    flex-direction: column;\n    gap: var(--spacing-md);\n  }\n\n  .shop-header-right {\n    width: 100%;\n    justify-content: space-between;\n  }\n\n  .shop-tabs {\n    flex-wrap: wrap;\n  }\n\n  .shop-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .resource-display {\n    flex-wrap: wrap;\n    gap: var(--spacing-md);\n  }\n}\n\n:root {\n  /* =========================================================================\n     ARDYCIA COLOR GUIDE - Primary Palette\n     ========================================================================= */\n\n  /* Whites & Lights */\n  --ard-white: #fefefe;\n  --ard-off-white: #ededec;\n  --ard-silver: #dcd7d9;\n  --ard-mist: #c1c3c4;\n\n  /* Neutrals & Grays */\n  --ard-warm-gray: #aaa0a0;\n  --ard-cool-gray: #8d8c80;\n  --ard-slate: #6d6e7d;\n  --ard-charcoal: #585150;\n  --ard-dark: #252424;\n\n  /* Browns & Earth */\n  --ard-brown-dark: #4d3f34;\n  --ard-brown-mid: #806d4e;\n  --ard-tan: #bd8b75;\n  --ard-peach: #e6b7a8;\n  --ard-sage: #abbab1;\n\n  /* Warm Accents - Primary UI */\n  --ard-gold: #f3a310;\n  --ard-amber: #eb9c65;\n  --ard-rust: #c5631f;\n  --ard-terracotta: #823416;\n\n  /* Reds & Pinks */\n  --ard-crimson: #c3132c;\n  --ard-coral: #f06b58;\n  --ard-rose: #ab544c;\n  --ard-magenta: #c12185;\n\n  /* Greens */\n  --ard-emerald: #25967a;\n  --ard-forest: #288d28;\n  --ard-olive: #75a253;\n\n  /* Blues & Purples */\n  --ard-sky: #84c1e6;\n  --ard-ocean: #4984ba;\n  --ard-cyan: #02bdfe;\n  --ard-navy: #232173;\n  --ard-lavender: #b076d6;\n\n  /* =========================================================================\n     SEMANTIC COLOR MAPPINGS\n     ========================================================================= */\n\n  /* Backgrounds */\n  --bg-primary: var(--ard-dark);\n  --bg-secondary: var(--ard-brown-dark);\n  --bg-tertiary: var(--ard-charcoal);\n  --bg-surface: rgba(37, 36, 36, 0.95);\n  --bg-overlay: rgba(37, 36, 36, 0.9);\n\n  /* Text */\n  --text-primary: var(--ard-off-white);\n  --text-secondary: var(--ard-sage);\n  --text-muted: var(--ard-cool-gray);\n  --text-accent: var(--ard-gold);\n  --text-highlight: var(--ard-amber);\n\n  /* Borders */\n  --border-primary: var(--ard-brown-mid);\n  --border-secondary: var(--ard-charcoal);\n  --border-accent: var(--ard-gold);\n  --border-subtle: rgba(128, 109, 78, 0.3);\n\n  /* Interactive States */\n  --interactive-default: var(--ard-brown-dark);\n  --interactive-hover: var(--ard-charcoal);\n  --interactive-active: var(--ard-rust);\n  --interactive-disabled: var(--ard-cool-gray);\n\n  /* Status Colors */\n  --status-success: var(--ard-emerald);\n  --status-warning: var(--ard-gold);\n  --status-error: var(--ard-crimson);\n  --status-info: var(--ard-sky);\n\n  /* Combat Colors */\n  --combat-player: var(--ard-emerald);\n  --combat-enemy: var(--ard-crimson);\n  --combat-damage: var(--ard-coral);\n  --combat-healing: var(--ard-forest);\n  --combat-buff: var(--ard-gold);\n  --combat-debuff: var(--ard-lavender);\n\n  /* Resource Colors */\n  --resource-wad: var(--ard-gold);\n  --resource-metal: var(--ard-cool-gray);\n  --resource-wood: var(--ard-tan);\n  --resource-chaos: var(--ard-lavender);\n  --resource-steam: var(--ard-sky);\n\n  /* Heat System */\n  --heat-cold: var(--ard-sky);\n  --heat-warm: var(--ard-gold);\n  --heat-hot: var(--ard-amber);\n  --heat-critical: var(--ard-crimson);\n\n  /* =========================================================================\n     LEGACY MAPPINGS (for backward compatibility)\n     ========================================================================= */\n\n  /* Map old variable names to new Ardycia colors */\n  --ardycia-earth-dark: var(--ard-dark);\n  --ardycia-earth-mid: var(--ard-brown-dark);\n  --ardycia-earth-light: var(--ard-charcoal);\n\n  --slk-green: var(--ard-emerald);\n  --slk-green-dim: #1a5d4a;\n  --slk-green-glow: rgba(37, 150, 122, 0.3);\n  --slk-amber: var(--ard-gold);\n  --slk-red: var(--ard-coral);\n  --slk-teal: var(--ard-sky);\n  --slk-violet: var(--ard-lavender);\n\n  --bronze: var(--ard-rust);\n  --bronze-dark: var(--ard-terracotta);\n  --bronze-light: var(--ard-amber);\n\n  /* =========================================================================\n     TYPOGRAPHY\n     ========================================================================= */\n\n  --font-display: \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif;\n  --font-mono: \"Consolas\", \"Monaco\", \"Lucida Console\", monospace;\n  --font-size-xs: 0.65rem;\n  --font-size-sm: 0.75rem;\n  --font-size-md: 0.875rem;\n  --font-size-lg: 1rem;\n  --font-size-xl: 1.25rem;\n  --font-size-2xl: 1.5rem;\n  --font-size-3xl: 2rem;\n\n  /* =========================================================================\n     SPACING & SIZING\n     ========================================================================= */\n\n  --spacing-xs: 0.25rem;\n  --spacing-sm: 0.5rem;\n  --spacing-md: 0.75rem;\n  --spacing-lg: 1rem;\n  --spacing-xl: 1.5rem;\n  --spacing-2xl: 2rem;\n\n  --radius-sm: 3px;\n  --radius-md: 4px;\n  --radius-lg: 6px;\n  --radius-xl: 8px;\n\n  /* =========================================================================\n     SHADOWS\n     ========================================================================= */\n\n  /* Shadows - Defaults (overridden by theme) */\n  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);\n  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);\n  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);\n  --shadow-glow: 0 0 20px rgba(243, 163, 16, 0.3);\n  --shadow-glow-accent: 0 0 20px rgba(37, 150, 122, 0.3);\n  --shadow-glow-error: 0 0 20px rgba(195, 19, 44, 0.3);\n  --shadow-glow-gold: var(--shadow-glow);\n  --shadow-glow-emerald: var(--shadow-glow-accent);\n  --shadow-glow-crimson: var(--shadow-glow-error);\n}\n\n/* ==========================================================================\n   RESPONSIVE LAYOUT FIXES - Fit Everything in Window\n   ========================================================================== */\n\n/* Prevent overflow on all major containers */\n\nhtml,\nbody {\n  overflow-x: hidden;\n  max-width: 100vw;\n}\n\n/* Base app container */\n\n#app {\n  min-height: 100vh;\n  max-height: 100vh;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n}\n\n/* Universal box sizing */\n\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n}\n\n/* ==========================================================================\n   GLOBAL BUTTON STYLES - PC Roguelike Style (Crisp, Minimal)\n   ========================================================================== */\n\n.btn-primary {\n  background: var(--ard-rust);\n  border: 2px solid var(--ard-gold);\n  color: var(--ard-off-white);\n  padding: 0.75rem 1.5rem;\n  border-radius: var(--radius-md);\n  font-family: var(--font-display);\n  font-weight: 700;\n  font-size: var(--font-size-sm);\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  cursor: pointer;\n  transition: all 0.15s ease;\n  box-shadow: none;\n}\n\n.btn-primary:hover:not(:disabled) {\n  background: var(--ard-amber);\n  border-color: var(--ard-gold);\n  color: var(--ard-dark);\n  transform: translateY(-1px);\n  box-shadow: var(--shadow-sm);\n}\n\n.btn-primary:active:not(:disabled) {\n  transform: translateY(0);\n  box-shadow: none;\n}\n\n.btn-primary:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n  background: var(--ard-charcoal);\n  border-color: var(--ard-cool-gray);\n  color: var(--ard-cool-gray);\n}\n\n.btn-secondary {\n  background: var(--ard-dark);\n  border: 1px solid var(--ard-brown-mid);\n  color: var(--ard-sage);\n  padding: 0.6rem 1.25rem;\n  border-radius: var(--radius-md);\n  font-family: var(--font-display);\n  font-weight: 600;\n  font-size: var(--font-size-sm);\n  cursor: pointer;\n  transition: all 0.15s ease;\n  box-shadow: none;\n}\n\n.btn-secondary:hover:not(:disabled) {\n  background: var(--ard-brown-dark);\n  border-color: var(--ard-rust);\n  color: var(--ard-off-white);\n  transform: translateY(-1px);\n}\n\n.btn-secondary:active:not(:disabled) {\n  transform: translateY(0);\n}\n\n.btn-secondary:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n.btn-danger {\n  background: var(--ard-dark);\n  border: 1px solid var(--ard-crimson);\n  color: var(--ard-coral);\n  padding: 0.6rem 1.25rem;\n  border-radius: var(--radius-md);\n  font-family: var(--font-display);\n  font-weight: 600;\n  font-size: var(--font-size-sm);\n  cursor: pointer;\n  transition: all 0.15s ease;\n  box-shadow: none;\n}\n\n.btn-danger:hover:not(:disabled) {\n  background: rgba(195, 19, 44, 0.2);\n  border-color: var(--ard-coral);\n  color: var(--ard-off-white);\n  transform: translateY(-1px);\n}\n\n.btn-danger:active:not(:disabled) {\n  transform: translateY(0);\n}\n\n/* ==========================================================================\n   BATTLE RESULT OVERLAY - Victory/Defeat (FIXED)\n   ========================================================================== */\n\n.battle-result-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(37, 36, 36, 0.95);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n  animation: fadeIn 0.3s ease;\n  pointer-events: auto;\n}\n\n@keyframes fadeIn {\n  from {\n    opacity: 0;\n  }\n\n  to {\n    opacity: 1;\n  }\n}\n\n.battle-result-card {\n  background: linear-gradient(180deg,\n      var(--ard-brown-dark) 0%,\n      var(--ard-dark) 100%);\n  border: 2px solid var(--ard-gold);\n  border-radius: var(--radius-lg);\n  padding: 2rem 3rem;\n  min-width: 400px;\n  max-width: 90vw;\n  text-align: center;\n  box-shadow:\n    var(--shadow-lg),\n    0 0 40px rgba(243, 163, 16, 0.2);\n  animation: scaleIn 0.3s ease;\n}\n\n@keyframes scaleIn {\n  from {\n    transform: scale(0.9);\n    opacity: 0;\n  }\n\n  to {\n    transform: scale(1);\n    opacity: 1;\n  }\n}\n\n.battle-result-overlay--defeat .battle-result-card {\n  border-color: var(--ard-crimson);\n  box-shadow:\n    var(--shadow-lg),\n    0 0 40px rgba(195, 19, 44, 0.2);\n}\n\n.battle-result-title {\n  font-size: 2.5rem;\n  font-weight: 700;\n  color: var(--ard-gold);\n  text-transform: uppercase;\n  letter-spacing: 0.2em;\n  margin-bottom: 1.5rem;\n  text-shadow: 0 0 20px rgba(243, 163, 16, 0.5);\n}\n\n.battle-result-overlay--defeat .battle-result-title {\n  color: var(--ard-crimson);\n  text-shadow: 0 0 20px rgba(195, 19, 44, 0.5);\n}\n\n.battle-reward-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));\n  gap: 1rem;\n  margin-bottom: 2rem;\n}\n\n.battle-reward-item {\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid var(--ard-brown-mid);\n  border-radius: var(--radius-md);\n  padding: 0.75rem;\n}\n\n.reward-label {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-cool-gray);\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 0.25rem;\n}\n\n.reward-value {\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  color: var(--ard-emerald);\n}\n\n.battle-defeat-text {\n  color: var(--ard-sage);\n  font-size: var(--font-size-md);\n  margin-bottom: 1.5rem;\n}\n\n.battle-result-footer {\n  margin-top: 1rem;\n}\n\n/* THE FIX: Make sure claim button is clickable and visible */\n\n.battle-result-btn {\n  display: inline-block;\n  padding: 1rem 2rem;\n  background: var(--gradient-button);\n  border: 2px solid var(--ard-gold);\n  border-radius: var(--radius-md);\n  color: var(--ard-off-white);\n  font-family: var(--font-display);\n  font-size: var(--font-size-md);\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  z-index: 501;\n  position: relative;\n}\n\n.battle-result-btn:hover {\n  background: var(--gradient-button-hover);\n  border-color: var(--ard-amber);\n  transform: translateY(-2px);\n  box-shadow:\n    0 4px 20px rgba(0, 0, 0, 0.3),\n    var(--shadow-glow-gold);\n}\n\n.battle-result-btn:active {\n  transform: translateY(0);\n}\n\n/* ==========================================================================\n   WEAPON WINDOW STYLES - With Clutch Toggles & Node Diagram\n   ========================================================================== */\n\n.weapon-window {\n  background: var(--bg-surface);\n  border: 1px solid var(--border-primary);\n  border-radius: var(--radius-md);\n  padding: var(--spacing-md);\n  font-family: var(--font-display);\n  max-height: 100%;\n  overflow-y: auto;\n}\n\n.weapon-window--destroyed {\n  opacity: 0.6;\n  filter: grayscale(50%);\n}\n\n.weapon-window-header {\n  border-bottom: 1px solid var(--border-subtle);\n  padding-bottom: var(--spacing-sm);\n  margin-bottom: var(--spacing-md);\n}\n\n.weapon-window-title {\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  color: var(--ard-gold);\n  text-transform: uppercase;\n}\n\n.weapon-window-type {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-cool-gray);\n  margin-top: 0.15rem;\n}\n\n/* Weapon Stats */\n\n.weapon-stats-panel {\n  display: flex;\n  flex-direction: column;\n  gap: var(--spacing-sm);\n}\n\n.weapon-stat-row {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-sm);\n}\n\n.weapon-stat-label {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-sage);\n  width: 50px;\n  flex-shrink: 0;\n}\n\n.weapon-stat-bar {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-sm);\n}\n\n.weapon-stat-bar-track {\n  flex: 1;\n  height: 8px;\n  background: var(--ard-dark);\n  border-radius: 4px;\n  overflow: hidden;\n}\n\n.weapon-stat-bar-fill {\n  height: 100%;\n  background: var(--ard-gold);\n  transition: width 0.3s ease;\n}\n\n.weapon-stat-bar-fill--ammo {\n  background: var(--ard-sky);\n}\n\n.weapon-stat-value {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-off-white);\n  min-width: 45px;\n  text-align: right;\n}\n\n.weapon-jammed-badge {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  background: var(--ard-crimson);\n  color: var(--ard-off-white);\n  padding: 0.15rem 0.4rem;\n  border-radius: var(--radius-sm);\n  animation: pulse 1s infinite;\n}\n\n@keyframes pulse {\n\n  0%,\n  100% {\n    opacity: 1;\n  }\n\n  50% {\n    opacity: 0.6;\n  }\n}\n\n/* Wear Display */\n\n.weapon-wear-display {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-sm);\n}\n\n.weapon-wear-pips {\n  display: flex;\n  gap: 3px;\n}\n\n.weapon-wear-pip {\n  width: 12px;\n  height: 12px;\n  border: 1px solid var(--ard-cool-gray);\n  border-radius: 2px;\n  background: transparent;\n}\n\n.weapon-wear-pip--filled {\n  background: var(--ard-coral);\n  border-color: var(--ard-crimson);\n}\n\n.weapon-wear-value {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-sage);\n}\n\n.weapon-penalty-row {\n  display: flex;\n  gap: var(--spacing-sm);\n  padding: var(--spacing-xs) var(--spacing-sm);\n  background: rgba(195, 19, 44, 0.1);\n  border-radius: var(--radius-sm);\n}\n\n.weapon-penalty {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-coral);\n}\n\n/* Clutch Section - PROMINENT TOGGLES */\n\n.weapon-clutch-section {\n  margin-top: var(--spacing-md);\n}\n\n.weapon-clutch-btn {\n  width: 100%;\n  padding: var(--spacing-md);\n  background: var(--ard-dark);\n  border: 2px solid var(--ard-brown-mid);\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  transition: all 0.2s ease;\n  text-align: left;\n}\n\n.weapon-clutch-btn:hover {\n  background: var(--ard-brown-dark);\n  border-color: var(--ard-gold);\n}\n\n.weapon-clutch-btn--active {\n  background: rgba(243, 163, 16, 0.15);\n  border-color: var(--ard-gold);\n  box-shadow: inset 0 0 20px rgba(243, 163, 16, 0.1);\n}\n\n.weapon-clutch-btn--active:hover {\n  background: rgba(243, 163, 16, 0.25);\n}\n\n.weapon-clutch-label {\n  font-size: var(--font-size-sm);\n  font-weight: 600;\n  color: var(--ard-gold);\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-bottom: 0.25rem;\n}\n\n.weapon-clutch-effect {\n  font-size: var(--font-size-xs);\n  color: var(--ard-sage);\n  line-height: 1.4;\n}\n\n/* Weapon Actions */\n\n.weapon-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--spacing-xs);\n  margin-top: var(--spacing-md);\n  padding-top: var(--spacing-sm);\n  border-top: 1px solid var(--border-subtle);\n}\n\n.weapon-action-btn {\n  flex: 1;\n  min-width: 80px;\n  padding: var(--spacing-sm);\n  background: var(--ard-dark);\n  border: 1px solid var(--ard-brown-mid);\n  border-radius: var(--radius-sm);\n  color: var(--ard-sage);\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.weapon-action-btn:hover {\n  background: var(--ard-brown-dark);\n  border-color: var(--ard-rust);\n  color: var(--ard-off-white);\n}\n\n.weapon-action-btn--vent {\n  border-color: var(--ard-coral);\n  color: var(--ard-coral);\n}\n\n.weapon-action-btn--vent:hover {\n  background: rgba(240, 107, 88, 0.1);\n}\n\n.weapon-action-cost {\n  opacity: 0.7;\n}\n\n/* Destroyed Overlay */\n\n.weapon-destroyed-overlay {\n  position: absolute;\n  inset: 0;\n  background: rgba(37, 36, 36, 0.9);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  border-radius: var(--radius-md);\n}\n\n.weapon-destroyed-text {\n  font-size: var(--font-size-lg);\n  font-weight: 700;\n  color: var(--ard-crimson);\n  text-transform: uppercase;\n}\n\n.weapon-destroyed-hint {\n  font-size: var(--font-size-xs);\n  color: var(--ard-cool-gray);\n  margin-top: var(--spacing-sm);\n}\n\n/* ==========================================================================\n   WEAPON NODE DIAGRAM - Part Status Display\n   ========================================================================== */\n\n.weapon-node-diagram {\n  background: var(--ard-dark);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius-md);\n  padding: var(--spacing-md);\n  margin-top: var(--spacing-md);\n}\n\n.weapon-node-title {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-gold);\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: var(--spacing-sm);\n  text-align: center;\n}\n\n.weapon-node-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: var(--spacing-xs);\n}\n\n.weapon-node {\n  position: relative;\n  background: var(--ard-brown-dark);\n  border: 1px solid var(--ard-brown-mid);\n  border-radius: var(--radius-sm);\n  padding: var(--spacing-sm);\n  text-align: center;\n  cursor: help;\n  transition: all 0.2s ease;\n}\n\n.weapon-node:hover {\n  border-color: var(--ard-gold);\n  z-index: 10;\n}\n\n.weapon-node--ok {\n  border-color: var(--ard-emerald);\n}\n\n.weapon-node--ok .weapon-node-status {\n  color: var(--ard-emerald);\n}\n\n.weapon-node--damaged {\n  border-color: var(--ard-gold);\n  background: rgba(243, 163, 16, 0.1);\n}\n\n.weapon-node--damaged .weapon-node-status {\n  color: var(--ard-gold);\n}\n\n.weapon-node--broken {\n  border-color: var(--ard-coral);\n  background: rgba(240, 107, 88, 0.1);\n}\n\n.weapon-node--broken .weapon-node-status {\n  color: var(--ard-coral);\n}\n\n.weapon-node--destroyed {\n  border-color: var(--ard-crimson);\n  background: rgba(195, 19, 44, 0.2);\n}\n\n.weapon-node--destroyed .weapon-node-status {\n  color: var(--ard-crimson);\n}\n\n.weapon-node-id {\n  font-size: var(--font-size-lg);\n  font-weight: 700;\n  color: var(--ard-off-white);\n  margin-bottom: 0.15rem;\n}\n\n.weapon-node-name {\n  font-size: var(--font-size-xs);\n  font-family: var(--font-mono);\n  color: var(--ard-sage);\n  text-transform: uppercase;\n  margin-bottom: 0.15rem;\n}\n\n.weapon-node-status {\n  font-size: var(--font-size-xs);\n  font-weight: 600;\n}\n\n/* Node Tooltip */\n\n.weapon-node-tooltip {\n  position: absolute;\n  bottom: 100%;\n  left: 50%;\n  transform: translateX(-50%);\n  background: var(--ard-dark);\n  border: 1px solid var(--ard-gold);\n  border-radius: var(--radius-md);\n  padding: var(--spacing-sm);\n  min-width: 150px;\n  opacity: 0;\n  visibility: hidden;\n  transition: all 0.2s ease;\n  z-index: 100;\n  margin-bottom: var(--spacing-xs);\n}\n\n.weapon-node:hover .weapon-node-tooltip {\n  opacity: 1;\n  visibility: visible;\n}\n\n.weapon-node-tooltip-title {\n  font-size: var(--font-size-xs);\n  font-weight: 600;\n  color: var(--ard-gold);\n  margin-bottom: 0.25rem;\n}\n\n.weapon-node-tooltip-effect {\n  font-size: var(--font-size-xs);\n  color: var(--ard-coral);\n  line-height: 1.3;\n}\n\n/* ==========================================================================\n   RESPONSIVE SCALING\n   ========================================================================== */\n\n/* Small screens */\n\n@media (max-height: 700px) {\n  :root {\n    --font-size-xs: 0.6rem;\n    --font-size-sm: 0.7rem;\n    --font-size-md: 0.8rem;\n    --font-size-lg: 0.9rem;\n    --spacing-sm: 0.35rem;\n    --spacing-md: 0.5rem;\n  }\n\n  .battle-result-card {\n    padding: 1.5rem 2rem;\n    min-width: 300px;\n  }\n\n  .battle-result-title {\n    font-size: 1.8rem;\n    margin-bottom: 1rem;\n  }\n}\n\n/* Very small screens */\n\n@media (max-height: 550px) {\n  .battle-reward-grid {\n    grid-template-columns: repeat(5, 1fr);\n    gap: 0.5rem;\n  }\n\n  .battle-reward-item {\n    padding: 0.5rem;\n  }\n\n  .reward-label {\n    font-size: 0.5rem;\n  }\n\n  .reward-value {\n    font-size: 0.8rem;\n  }\n}\n\n/* Wide screens */\n\n@media (min-width: 1600px) {\n  :root {\n    --font-size-xs: 0.7rem;\n    --font-size-sm: 0.85rem;\n    --font-size-md: 1rem;\n    --font-size-lg: 1.15rem;\n  }\n}\n\n/* ==========================================================================\n   SCROLLBAR STYLING\n   ========================================================================== */\n\n::-webkit-scrollbar {\n  width: 8px;\n  height: 8px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--ard-dark);\n}\n\n::-webkit-scrollbar-thumb {\n  background: var(--ard-brown-mid);\n  border-radius: 4px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: var(--ard-rust);\n}\n\n/* Firefox */\n\n* {\n  scrollbar-width: thin;\n  scrollbar-color: var(--ard-brown-mid) var(--ard-dark);\n}\n\n/* ==========================================================================\n   CHAOS CORE - MAIN MENU & SETTINGS (Ardycia Unified)\n   Add this AFTER ardycia-unified.css in your styles.css\n   ========================================================================== */\n\n/* ==========================================================================\n   MAIN MENU\n   ========================================================================== */\n\n.mainmenu-root {\n  min-height: 100vh;\n  height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background:\n    url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E\"),\n    radial-gradient(ellipse at center,\n      var(--ard-brown-dark) 0%,\n      var(--ard-dark) 70%,\n      #0d0b09 100%);\n  font-family: var(--font-display);\n  color: var(--ard-sage);\n  position: relative;\n  overflow: hidden;\n}\n\n.mainmenu-bg-effects {\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n}\n\n.mainmenu-scanline {\n  position: absolute;\n  inset: 0;\n  background: repeating-linear-gradient(0deg,\n      transparent,\n      transparent 2px,\n      rgba(0, 0, 0, 0.1) 2px,\n      rgba(0, 0, 0, 0.1) 4px);\n  animation: scanline-scroll 8s linear infinite;\n}\n\n@keyframes scanline-scroll {\n  from {\n    transform: translateY(0);\n  }\n\n  to {\n    transform: translateY(100px);\n  }\n}\n\n.mainmenu-vignette {\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(ellipse at center,\n      transparent 40%,\n      rgba(0, 0, 0, 0.6) 100%);\n}\n\n/* Two-column layout: Left (logo/menu) and Right (terminal) */\n\n.mainmenu-content {\n  position: relative;\n  display: flex;\n  flex-direction: row;\n  align-items: flex-start;\n  justify-content: flex-start;\n  min-height: 100vh;\n  padding: 2.5rem 2rem 2rem 2rem;\n  box-sizing: border-box;\n  z-index: 1;\n  gap: 2rem;\n  max-width: 100vw;\n  overflow-x: hidden;\n  overflow-y: auto;\n}\n\n/* Left panel: Logo and Menu */\n\n.mainmenu-left-panel {\n  display: flex;\n  flex-direction: column;\n  gap: 2rem;\n  flex-shrink: 0;\n  width: 420px;\n  max-width: 420px;\n  min-width: 0;\n  overflow: visible;\n}\n\n/* Logo section - top of left panel */\n\n.mainmenu-logo-section {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: 0.75rem;\n  flex-shrink: 0;\n}\n\n/* Logo Container */\n\n.mainmenu-logo-container {\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  justify-content: flex-start;\n  width: 100%;\n  max-width: 100%;\n  overflow: visible;\n  padding: 0.5rem 0;\n}\n\n/* Logo Image */\n\n.mainmenu-logo-image {\n  width: 100% !important;\n  max-width: 100% !important;\n  height: auto !important;\n  object-fit: contain !important;\n  filter: drop-shadow(0 0 40px rgba(195, 19, 44, 0.4)) !important;\n  animation: logo-pulse 3s ease-in-out infinite;\n  display: block;\n}\n\n@keyframes logo-pulse {\n\n  0%,\n  100% {\n    filter: drop-shadow(0 0 40px rgba(195, 19, 44, 0.4));\n  }\n\n  50% {\n    filter: drop-shadow(0 0 60px rgba(195, 19, 44, 0.6));\n  }\n}\n\n/* Fallback text logo */\n\n.mainmenu-logo-fallback {\n  font-size: 3.5rem;\n  font-weight: 700;\n  color: var(--ard-crimson);\n  text-transform: uppercase;\n  letter-spacing: 0.15em;\n  text-shadow:\n    0 0 20px rgba(195, 19, 44, 0.5),\n    0 0 40px rgba(195, 19, 44, 0.3);\n  text-align: left;\n}\n\n/* Logo glow effect */\n\n.mainmenu-logo-glow {\n  position: absolute;\n  width: 450px;\n  height: 350px;\n  background: radial-gradient(ellipse at center,\n      rgba(195, 19, 44, 0.12) 0%,\n      transparent 65%);\n  pointer-events: none;\n  z-index: -1;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  overflow: visible;\n}\n\n/* Subtitle */\n\n.mainmenu-subtitle {\n  font-size: 0.7rem;\n  font-family: var(--font-mono);\n  color: var(--ard-cool-gray);\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  text-align: left;\n  margin-top: 0.5rem;\n}\n\n/* Menu section - below logo */\n\n.mainmenu-menu-section {\n  display: flex;\n  flex-dir