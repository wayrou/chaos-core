lect:focus {\n  outline: none;\n  border-color: #a87c45;\n}\n\n/* Controller Status */\n\n.controller-status {\n  padding: 1rem;\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(168, 124, 69, 0.15);\n  border-radius: 4px;\n}\n\n.controller-connected {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  color: #35ff95;\n  margin-bottom: 0.5rem;\n}\n\n.controller-connected .status-icon {\n  font-size: 1.2rem;\n}\n\n.controller-disconnected {\n  text-align: center;\n  padding: 1rem;\n}\n\n.controller-disconnected .status-icon {\n  font-size: 2rem;\n  color: #6b4f2d;\n  display: block;\n  margin-bottom: 0.5rem;\n}\n\n.controller-disconnected .status-text {\n  color: #a87c45;\n  margin-bottom: 0.25rem;\n}\n\n.controller-disconnected .status-hint {\n  font-size: 0.6rem;\n  color: #6b4f2d;\n}\n\n.controller-info {\n  font-size: 0.6rem;\n  font-family: \"Consolas\", monospace;\n  color: #6b4f2d;\n  padding: 0.25rem 0;\n}\n\n/* Bindings */\n\n.bindings-list,\n.keyboard-bindings {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n}\n\n.binding-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.5rem 0.75rem;\n  background: rgba(0, 0, 0, 0.15);\n  border-radius: 3px;\n}\n\n.binding-action {\n  font-size: 0.7rem;\n  color: #c9a66b;\n}\n\n.binding-buttons,\n.binding-keys {\n  font-size: 0.6rem;\n  font-family: \"Consolas\", monospace;\n  color: #a87c45;\n}\n\n.binding-button {\n  display: inline-block;\n  padding: 0.15rem 0.4rem;\n  background: rgba(168, 124, 69, 0.2);\n  border-radius: 2px;\n  margin-left: 0.25rem;\n}\n\n/* Saves Tab */\n\n.saves-list {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.saves-loading {\n  text-align: center;\n  padding: 2rem;\n  color: #6b4f2d;\n}\n\n.saves-empty {\n  text-align: center;\n  padding: 2rem;\n}\n\n.saves-empty-icon {\n  font-size: 2.5rem;\n  margin-bottom: 0.5rem;\n  opacity: 0.5;\n}\n\n.saves-empty-text {\n  color: #6b4f2d;\n}\n\n.save-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.75rem 1rem;\n  background: rgba(0, 0, 0, 0.2);\n  border: 1px solid rgba(168, 124, 69, 0.15);\n  border-radius: 4px;\n}\n\n.save-item--autosave {\n  border-color: rgba(53, 255, 149, 0.3);\n}\n\n.save-info {\n  flex: 1;\n}\n\n.save-timestamp {\n  font-size: 0.6rem;\n  font-family: \"Consolas\", monospace;\n  color: #6b4f2d;\n  margin-bottom: 0.25rem;\n}\n\n.save-preview {\n  display: flex;\n  gap: 0.5rem;\n  font-size: 0.55rem;\n}\n\n.preview-callsign,\n.preview-operation,\n.preview-wad {\n  color: #a87c45;\n}\n\n.preview-separator {\n  color: #4a3d28;\n}\n\n.save-actions {\n  flex-shrink: 0;\n}\n\n.save-delete-btn {\n  padding: 0.4rem 0.6rem;\n  background: rgba(255, 107, 107, 0.1);\n  border: 1px solid rgba(255, 107, 107, 0.3);\n  border-radius: 3px;\n  color: #ff6b6b;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.save-delete-btn:hover {\n  background: rgba(255, 107, 107, 0.2);\n  border-color: #ff6b6b;\n}\n\n/* Data Management */\n\n.data-actions {\n  padding: 1rem;\n  text-align: center;\n}\n\n.data-action-btn {\n  padding: 0.75rem 1.5rem;\n  background: #2d261f;\n  border: 1px solid #6b4f2d;\n  border-radius: 4px;\n  color: #c9a66b;\n  font-family: inherit;\n  font-size: 0.75rem;\n  font-weight: 500;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.data-action-btn--danger {\n  border-color: rgba(255, 107, 107, 0.5);\n  color: #ff6b6b;\n}\n\n.data-action-btn--danger:hover {\n  background: rgba(255, 107, 107, 0.1);\n  border-color: #ff6b6b;\n}\n\n.data-action-warning {\n  font-size: 0.55rem;\n  color: #6b4f2d;\n  margin-top: 0.5rem;\n}\n\n/* Footer */\n\n.settings-footer {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.75rem 1rem;\n  margin-top: 1rem;\n}\n\n.settings-reset-btn {\n  padding: 0.5rem 1rem;\n  background: rgba(255, 107, 107, 0.1);\n  border: 1px solid rgba(255, 107, 107, 0.3);\n  border-radius: 3px;\n  color: #ff6b6b;\n  font-family: inherit;\n  font-size: 0.65rem;\n  font-weight: 500;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.settings-reset-btn:hover {\n  background: rgba(255, 107, 107, 0.2);\n  border-color: #ff6b6b;\n}\n\n.settings-version {\n  font-size: 0.5rem;\n  font-family: \"Consolas\", monospace;\n  color: #4a3d28;\n}\n\n/* ==========================================================================\n   CONTROLLER FOCUS\n   ========================================================================== */\n\n.controller-focusable:focus {\n  outline: none;\n}\n\n.controller-focused {\n  outline: 2px solid #ffcc6e !important;\n  outline-offset: 2px;\n  box-shadow: 0 0 15px rgba(255, 204, 110, 0.4) !important;\n}\n\n/* ==========================================================================\n   ACCESSIBILITY\n   ========================================================================== */\n\n.high-contrast .setting-label,\n.high-contrast .mainmenu-btn {\n  color: #ffffff;\n}\n\n.high-contrast .setting-description {\n  color: #cccccc;\n}\n\n.large-text {\n  font-size: 18px;\n}\n\n.large-text .setting-label {\n  font-size: 1rem;\n}\n\n.large-text .setting-description {\n  font-size: 0.8rem;\n}\n\n.reduced-motion * {\n  animation: none !important;\n  transition: none !important;\n}\n\n/* ==========================================================================\n   SCROLLBAR\n   ========================================================================== */\n\n.settings-content::-webkit-scrollbar,\n.mainmenu-modal-body::-webkit-scrollbar {\n  width: 6px;\n}\n\n.settings-content::-webkit-scrollbar-track,\n.mainmenu-modal-body::-webkit-scrollbar-track {\n  background: #1a1612;\n}\n\n.settings-content::-webkit-scrollbar-thumb,\n.mainmenu-modal-body::-webkit-scrollbar-thumb {\n  background: #6b4f2d;\n  border-radius: 3px;\n}\n\n.settings-content::-webkit-scrollbar-thumb:hover,\n.mainmenu-modal-body::-webkit-scrollbar-thumb:hover {\n  background: #a87c45;\n}\n\n/* ==========================================================================\n   BASECAMP NAVIGATION BAR (Headline 12bza)\n   ========================================================================== */\n\n.basecamp-topnav {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.5rem 1rem;\n  background: linear-gradient(180deg,\n      rgba(45, 38, 31, 0.9) 0%,\n      rgba(26, 22, 18, 0.95) 100%);\n  border-bottom: 1px solid rgba(168, 124, 69, 0.3);\n  margin-bottom: 0;\n}\n\n.basecamp-topnav-spacer {\n  flex: 1;\n}\n\n.bc-nav-btn {\n  display: flex;\n  align-items: center;\n  gap: 0.4rem;\n  padding: 0.5rem 0.75rem;\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid rgba(168, 124, 69, 0.3);\n  border-radius: 4px;\n  color: #a87c45;\n  font-family: inherit;\n  font-size: 0.7rem;\n  font-weight: 500;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.bc-nav-btn:hover {\n  background: rgba(168, 124, 69, 0.15);\n  border-color: rgba(168, 124, 69, 0.5);\n  color: #c9a66b;\n}\n\n.bc-nav-btn .nav-icon {\n  font-size: 0.9rem;\n}\n\n.bc-nav-btn .nav-label {\n  font-size: 0.65rem;\n}\n\n.bc-nav-title:hover {\n  border-color: rgba(255, 107, 107, 0.5);\n  color: #ff8888;\n}\n\n.bc-nav-settings:hover {\n  border-color: rgba(53, 255, 149, 0.5);\n  color: #35ff95;\n}\n\n/* Update basecamp buttons to have icons */\n\n.bc-btn {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.25rem;\n}\n\n.bc-btn .btn-icon {\n  font-size: 1.5rem;\n}\n\n.bc-btn .btn-label {\n  font-size: 0.75rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n/* ==========================================================================\n   CHAOS CORE - SETTINGS & MAIN MENU STYLES (Headline 12)\n   Append this to your existing styles.css\n   ========================================================================== */\n\n/* ==========================================================================\n   MAIN MENU\n   ========================================================================== */\n\n.mainmenu-root {\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background:\n    url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E\"),\n    radial-gradient(ellipse at center, #2d261f 0%, #1a1612 70%, #0d0b09 100%);\n  font-family: \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif;\n  color: #c9a66b;\n  position: relative;\n  overflow: hidden;\n}\n\n.mainmenu-bg-effects {\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n}\n\n.mainmenu-scanline {\n  position: absolute;\n  inset: 0;\n  background: repeating-linear-gradient(0deg,\n      transparent,\n      transparent 2px,\n      rgba(0, 0, 0, 0.1) 2px,\n      rgba(0, 0, 0, 0.1) 4px);\n  animation: scanline-scroll 8s linear infinite;\n}\n\n@keyframes scanline-scroll {\n  from {\n    transform: translateY(0);\n  }\n\n  to {\n    transform: translateY(100px);\n  }\n}\n\n.mainmenu-vignette {\n  position: absolute;\n  inset: 0;\n  background: radial-gradient(ellipse at center,\n      transparent 40%,\n      rgba(0, 0, 0, 0.6) 100%);\n}\n\n/* Content wrapper - stacks logo + card vertically */\n\n.mainmenu-content {\n  display: flex;\n  flex-direction: row;\n  align-items: center;\n  justify-content: flex-start;\n  gap: 3rem;\n  z-index: 1;\n  padding: 2rem;\n  overflow: visible;\n  width: 100%;\n  max-width: 100%;\n}\n\n/* Logo Container - on the right side */\n\n.mainmenu-logo-container {\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 1rem;\n}\n\n/* Logo Image - 4x larger */\n\n.mainmenu-logo-image {\n  width: 1350px !important;\n  max-width: 90vw !important;\n  height: auto !important;\n  object-fit: contain !important;\n  filter: drop-shadow(0 0 40px rgba(195, 19, 44, 0.4)) !important;\n  animation: logo-pulse 3s ease-in-out infinite;\n}\n\n@keyframes logo-pulse {\n\n  0%,\n  100% {\n    filter: drop-shadow(0 0 30px rgba(255, 100, 50, 0.5));\n  }\n\n  50% {\n    filter: drop-shadow(0 0 50px rgba(255, 100, 50, 0.7));\n  }\n}\n\n/* Fallback text logo */\n\n.mainmenu-logo-fallback {\n  font-size: 4rem;\n  font-weight: 700;\n  color: #ffcc6e;\n  text-transform: uppercase;\n  letter-spacing: 0.15em;\n  text-shadow:\n    0 0 20px rgba(255, 204, 110, 0.5),\n    0 0 40px rgba(255, 204, 110, 0.3);\n  text-align: center;\n}\n\n/* Logo glow effect */\n\n.mainmenu-logo-glow {\n  position: absolute;\n  width: 1500px;\n  height: 1050px;\n  background: radial-gradient(ellipse at center,\n      rgba(195, 19, 44, 0.15) 0%,\n      transparent 60%);\n  pointer-events: none;\n  z-index: -1;\n}\n\n/* Subtitle - below logo, above card */\n\n.mainmenu-subtitle {\n  font-size: 0.75rem;\n  font-family: \"Consolas\", monospace;\n  color: #a87c45;\n  letter-spacing: 0.2em;\n  text-transform: uppercase;\n  text-align: center;\n  margin-bottom: 2rem;\n}\n\n/* Card - buttons only, no logo */\n\n.mainmenu-card {\n  background: linear-gradient(180deg,\n      rgba(45, 38, 31, 0.95) 0%,\n      rgba(26, 22, 18, 0.98) 100%);\n  border: 1px solid rgba(168, 124, 69, 0.4);\n  border-radius: 6px;\n  padding: 1.5rem 2rem;\n  max-width: 420px;\n  width: auto;\n  flex-shrink: 0;\n  margin-left: 2rem;\n  box-shadow:\n    0 0 60px rgba(0, 0, 0, 0.5),\n    0 0 30px rgba(168, 124, 69, 0.1),\n    inset 0 1px 0 rgba(255, 255, 255, 0.03);\n}\n\n.mainmenu-divider {\n  height: 1px;\n  background: linear-gradient(90deg,\n      transparent,\n      rgba(168, 124, 69, 0.4),\n      transparent);\n  margin: 1.5rem 0;\n}\n\n.mainmenu-buttons {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n  overfl