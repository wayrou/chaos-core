n\n/* Grid lines background effect - subtle tactical overlay using Ardycia colors */\n\n.opmap-floor-background::before {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background-image:\n    linear-gradient(rgba(243, 163, 16, 0.03) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(243, 163, 16, 0.03) 1px, transparent 1px);\n  background-size: 50px 50px;\n  pointer-events: none;\n  opacity: 0.4;\n}\n\n/* Fog of war overlay - subtle animated haze */\n\n.opmap-floor-background::after {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: radial-gradient(ellipse at center,\n      transparent 0%,\n      rgba(0, 0, 0, 0.3) 60%,\n      rgba(0, 0, 0, 0.6) 100%);\n  pointer-events: none;\n  z-index: 1;\n}\n\n/* Floating control panel - Ardycia style */\n\n.opmap-control-panel {\n  position: fixed;\n  top: var(--space-4, 1rem);\n  left: var(--space-4, 1rem);\n  width: 320px;\n  max-width: calc(100vw - var(--space-8, 2rem));\n  background: var(--bg-panel, #4d3f34);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n  z-index: 100;\n  overflow: hidden;\n  pointer-events: auto;\n}\n\n.opmap-panel-header {\n  padding: var(--space-3, 0.75rem) var(--space-4, 1rem);\n  background: var(--bg-panel-alt, #3b2f24);\n  border-bottom: var(--stroke-1, 1px) solid var(--stroke-panel, #7a5a32);\n}\n\n.opmap-panel-header-left {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1, 0.25rem);\n}\n\n.opmap-panel-title {\n  font-size: var(--text-lg, 1.125rem);\n  font-weight: var(--weight-bold, 700);\n  letter-spacing: var(--tracking-wider, 0.1em);\n  color: var(--ink-accent, #ffcc6e);\n  text-transform: uppercase;\n  margin: 0;\n}\n\n.opmap-panel-subtitle {\n  font-size: var(--text-xs, 0.6875rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\"