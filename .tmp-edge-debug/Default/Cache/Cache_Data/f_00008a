0, rgba(255, 204, 110, 0.3));\n  border-radius: var(--radius-sm, 3px);\n  font-size: var(--text-xs, 0.6rem);\n  font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n  color: var(--tech-amber, #ffcc6e);\n  text-align: center;\n}\n\n/* --------------------------------------------------------------------------\n   CRAFT TAB LAYOUT\n   -------------------------------------------------------------------------- */\n\n.crafting-tab-layout {\n  flex: 1;\n  min-height: 0;\n  display: grid;\n  grid-template-columns: minmax(220px, 250px) minmax(260px, 320px) minmax(0, 1fr);\n  gap: var(--space-3, 0.75rem);\n  width: 100%;\n  overflow: hidden;\n}\n\n.crafting-sidebar,\n.crafting-recipes,\n.crafting-details {\n  min-height: 0;\n}\n\n.crafting-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-3, 0.75rem);\n}\n\n.crafting-resources,\n.crafting-categories,\n.crafting-recipes,\n.crafting-details {\n  background: var(--bg-panel, rgba(20, 18, 15, 0.95));\n  border: var(--stroke-1, 1px) solid var(--stroke-subtle, rgba(168, 124, 69, 0.3));\n  border-radius: var(--radius-sm, 3px);\n  padding: var(--space-3, 0.75rem);\n  box-sizing: border-box;\n}\n\n.resource-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: var(--space-2, 0.5rem);\n}\n\n.resource-item {\n  display: grid;\n  grid-template-columns: 24px minmax(0, 1fr) auto;\n  gap: var(--space-1, 0.35rem);\n  align-items: center;\n  padding: var(--space-2, 0.45rem) var(--space-2, 0.5rem);\n  background: var(--bg-surface, #2d261f);\n  border: var(--stroke-1, 1px) solid rgba(168, 124, 69, 0.18);\n  border-radius: var(--radius-xs, 2px);\n}\n\n.resource-icon,\n.resource-value {\n  font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n}\n\n.resource-name {\n  min-width: 0;\n  font-size: var(--text-xs, 0.65rem);\n  color: var(--ink-secondary, #d6b686);\n}\n\n.resource-value {\n  font-size: var(--text-xs, 0.68rem);\n  color: var(--tech-teal, #8ce6ff);\n}\n\n.cate