----------------------------------------------\n     ARDYCIA PRIMARY PALETTE\n     ------------------------------------------------------------------------- */\n\n  /* Whites & Lights */\n  --ard-white: #fefefe;\n  --ard-off-white: #ededec;\n  --ard-silver: #dcd7d9;\n  --ard-mist: #c1c3c4;\n\n  /* Neutrals & Grays */\n  --ard-warm-gray: #aaa0a0;\n  --ard-cool-gray: #8d8c80;\n  --ard-slate: #6d6e7d;\n  --ard-charcoal: #585150;\n  --ard-dark: #252424;\n\n  /* Browns & Earth */\n  --ard-brown-dark: #4d3f34;\n  --ard-brown-mid: #806d4e;\n  --ard-tan: #bd8b75;\n  --ard-peach: #e6b7a8;\n  --ard-sage: #abbab1;\n\n  /* Warm Accents */\n  --ard-gold: #f3a310;\n  --ard-amber: #eb9c65;\n  --ard-rust: #c5631f;\n  --ard-terracotta: #823416;\n\n  /* Reds & Pinks */\n  --ard-crimson: #c3132c;\n  --ard-coral: #f06b58;\n  --ard-rose: #ab544c;\n  --ard-magenta: #c12185;\n\n  /* Greens */\n  --ard-emerald: #25967a;\n  --ard-forest: #288d28;\n  --ard-olive: #75a253;\n\n  /* Blues & Purples */\n  --ard-sky: #84c1e6;\n  --ard-ocean: #4984ba;\n  --ard-cyan: #02bdfe;\n  --ard-navy: #232173;\n  --ard-lavender: #b076d6;\n\n  /* -------------------------------------------------------------------------\n     SEMANTIC MAPPINGS\n     ------------------------------------------------------------------------- */\n\n  /* Backgrounds - Flat PC game style */\n  --bg-primary: var(--ard-dark);\n  --bg-secondary: var(--ard-brown-dark);\n  --bg-tertiary: var(--ard-charcoal);\n  --bg-surface: rgba(37, 36, 36, 0.98);\n  --bg-overlay: rgba(37, 36, 36, 0.95);\n  --bg-card: var(--ard-brown-dark);\n  /* Flat instead of gradient */\n\n  /* Text - Defaults (overridden by theme) */\n  --text-primary: var(--ard-off-white);\n  --text-secondary: var(--ard-sage);\n  --text-muted: var(--ard-cool-gray);\n  --text-accent: var(--ard-gold);\n  --text-highlight: var(--ard-amber);\n\n  /* Borders - Defaults (overridden by theme) */\n  --border-primary: var(--ard-brown-mid);\n  --border-secondary: var(--ard-charcoal);\n  --border-accent: var(--ard-gold);\n  --border-subtle: rgba(128, 109, 78, 0.3);\n\n  /* Gradients - Minimal/subtle for PC game style */\n  --gradient-primary: var(--ard-dark);\n  /* Flat */\n  --gradient-secondary: var(--ard-charcoal);\n  /* Flat */\n  --gradient-button: var(--ard-rust);\n  /* Flat */\n  --gradient-button-hover: var(--ard-amber);\n  /* Flat hover color */\n  --gradient-card: var(--ard-brown-dark);\n  /* Flat */\n  --gradient-header: var(--ard-dark);\n  /* Flat */\n\n  /* Interactive */\n  --interactive-default: var(--ard-brown-dark);\n  --interactive-hover: var(--ard-charcoal);\n  --interactive-active: var(--ard-rust);\n  --interactive-disabled: var(--ard-cool-gray);\n\n  /* Status */\n  --status-success: var(--ard-emerald);\n  --status-warning: var(--ard-gold);\n  --status-error: var(--ard-crimson);\n  --status-info: var(--ard-sky);\n\n  /* Combat */\n  --combat-player: var(--ard-emerald);\n  --combat-enemy: var(--ard-crimson);\n  --combat-damage: var(--ard-coral);\n  --combat-healing: var(--ard-forest);\n  --combat-buff: var(--ard-gold);\n  --combat-debuff: var(--ard-lavender);\n\n  /* Resources */\n  --resource-wad: var(--ard-gold);\n  --resource-metal: var(--ard-cool-gray);\n  --resource-wood: var(--ard-tan);\n  --resource-chaos: var(--ard-lavender);\n  --resource-steam: var(--ard-sky);\n\n  /* Heat System */\n  --heat-cold: var(--ard-sky);\n  --heat-warm: var(--ard-gold);\n  --heat-hot: var(--ard-amber);\n  --heat-critical: var(--ard-crimson);\n\n  /* Rarity */\n  --rarity-common: var(--ard-cool-gray);\n  --rarity-uncommon: var(--ard-emerald);\n  --rarity-rare: var(--ard-ocean);\n  --rarity-epic: var(--ard-lavender);\n  --rarity-legendary: var(--ard-gold);\n\n  /* -------------------------------------------------------------------------\n     TYPOGRAPHY\n     ------------------------------------------------------------------------- */\n\n  --font-display: \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif;\n  --font-mono: \"Consolas\", \"Monaco\", \"Lucida Console\", monospace;\n\n  --font-size-xs: 0.65rem;\n  --font-size-sm: 0.75rem;\n  --font-size-md: 0.875rem;\n  --font-size-lg: 1rem;\n  --font-size-xl: 1.25rem;\n  --font-size-2xl: 1.5rem;\n  --font-size-3xl: 2rem;\n\n  /* -------------------------------------------------------------------------\n     SPACING & SIZING\n     ------------------------------------------------------------------------- */\n\n  --spacing-xs: 0.25rem;\n  --spacing-sm: 0.5rem;\n  --spacing-md: 0.75rem;\n  --spacing-lg: 1rem;\n  --spacing-xl: 1.5rem;\n  --spacing-2xl: 2rem;\n\n  --radius-sm: 3px;\n  --radius-md: 4px;\n  --radius-lg: 6px;\n  --radius-xl: 8px;\n\n  /* -------------------------------------------------------------------------\n     SHADOWS\n     ------------------------------------------------------------------------- */\n\n  /* Shadows - Defaults (overridden by theme) */\n  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.3);\n  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);\n  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);\n  --shadow-glow: 0 0 20px rgba(243, 163, 16, 0.3);\n  --shadow-glow-accent: 0 0 20px rgba(37, 150, 122, 0.3);\n  --shadow-glow-error: 0 0 20px rgba(195, 19, 44, 0.3);\n  --shadow-glow-gold: var(--shadow-glow);\n  --shadow-glow-emerald: var(--shadow-glow-accent);\n  --shadow-glow-crimson: var(--shadow-glow-error);\n}\n\n/* ==========================================================================\n   BASE STYLES\n   ========================================================================== */\n\nhtml,\nbody {\n  margin: 0;\n  padding: 0;\n  overflow-x: hidden;\n  max-width: 100vw;\n  background: var(--gradient-primary);\n  color: var(--text-primary);\n  font-family: var(--font-display);\n}\n\n#app {\n  min-height: 100vh;\n  max-height: 100vh;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n}\n\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n}\n\n/* ==========================================================================\n   SHOP SCREEN STYLES - Ardycia Design System\n   ========================================================================== */\n\n.shop-root {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: var(--bg-world, #1a1917);\n  padding: var(--space-4, 1rem);\n  font-family: var(--font-ui, \"Inter\", sans-serif);\n  color: var(--ink, #e8e4dc);\n  overflow: hidden;\n}\n\n/* Header - Adventure Gothic Panel */\n\n.shop-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-3, 0.75rem) var(--space-4, 1rem);\n  background: var(--bg-panel-alt, #3b2f24);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  margin-bottom: var(--space-4, 1rem);\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n}\n\n.shop-header-left {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1, 0.25rem);\n}\n\n.shop-title {\n  font-size: var(--text-2xl, 1.5rem);\n  font-weight: var(--weight-bold, 700);\n  color: var(--ink-accent, #ffcc6e);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wider, 0.1em);\n  margin: 0;\n}\n\n.shop-subtitle {\n  font-size: var(--text-xs, 0.6875rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  color: var(--ink-muted, #6b6b6e);\n  letter-spacing: var(--tracking-widest, 0.15em);\n  text-transform: uppercase;\n}\n\n.shop-header-right {\n  display: flex;\n  align-items: center;\n  gap: var(--space-4, 1rem);\n}\n\n.shop-wallet {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n  padding: var(--space-2, 0.5rem) var(--space-4, 1rem);\n  background: var(--bg-surface, #2d2c2a);\n  border: var(--stroke-1, 1px) solid var(--accent-bronze, #a87c45);\n  border-radius: var(--radius-sm, 3px);\n}\n\n.wallet-label {\n  font-size: var(--text-xs, 0.6875rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  color: var(--ink-muted, #6b6b6e);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide, 0.05em);\n}\n\n.wallet-value {\n  font-size: var(--text-xl, 1.25rem);\n  font-weight: var(--weight-bold, 700);\n  color: var(--ink-accent, #ffcc6e);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n}\n\n.shop-back-btn {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2, 0.5rem);\n  padding: var(--space-2, 0.5rem) var(--space-4, 1rem);\n  background: var(--bg-surface, #2d2c2a);\n  border: var(--stroke-1, 1px) solid var(--stroke-subtle, rgba(168, 124, 69, 0.25));\n  border-radius: var(--radius-sm, 3px);\n  color: var(--ink-secondary, #a8a8a5);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  font-size: var(--text-xs, 0.6875rem);\n  font-weight: var(--weight-semibold, 600);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide, 0.05em);\n  cursor: pointer;\n  transition: all var(--transition-base, 0.15s ease);\n}\n\n.shop-back-btn:hover {\n  background: var(--interactive-hover, #6b5d4f);\n  border-color: var(--accent-bronze, #a87c45);\n  color: var(--ink, #e8e4dc);\n  transform: translateY(-1px);\n}\n\n.shop-back-btn:active {\n  transform: translateY(0);\n}\n\n/* Tabs - FFTA Style */\n\n.shop-tabs {\n  display: flex;\n  gap: var(--space-1, 0.25rem);\n  margin-bottom: var(--space-4, 1rem);\n  background: var(--bg-surface, #2d2c2a);\n  padding: var(--space-2, 0.5rem);\n  border-radius: var(--radius-md, 5px);\n}\n\n.shop-tab {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--space-2, 0.5rem);\n  padding: var(--space-2, 0.5rem) var(--space-4, 1rem);\n  background: transparent;\n  border: var(--stroke-1, 1px) solid transparent;\n  border-radius: var(--radius-sm, 3px);\n  color: var(--ink-muted, #6b6b6e);\n  font-family: var(--font-ui, \"Inter\", sans-serif);\n  font-size: var(--text-sm, 0.75rem);\n  font-weight: var(--weight-medium, 500);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide, 0.05em);\n  cursor: pointer;\n  transition: all var(--transition-base, 0.15s ease);\n}\n\n.shop-tab:hover {\n  background: var(--interactive-hover, #6b5d4f);\n  color: var(--ink, #e8e4dc);\n}\n\n.shop-tab--active {\n  background: var(--interactive-active, #a87c45);\n  border-color: var(--accent-bronze, #a87c45);\n  color: var(--ink-accent, #ffcc6e);\n  font-weight: var(--weight-semibold, 600);\n  box-shadow: 0 -2px 0 var(--tech-amber, #ffcc6e) inset;\n}\n\n.tab-icon {\n  font-size: var(--text-base, 0.875rem);\n}\n\n/* Content - World Panel */\n\n.shop-content {\n  flex: 1;\n  background: var(--bg-panel, #4d3f34);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  padding: var(--space-4, 1rem);\n  overflow-y: auto;\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n}\n\n.shop-section-header {\n  margin-bottom: var(--space-4, 1rem);\n}\n\n.section-title {\n  font-size: var(--text-lg, 1.125rem);\n  font-weight: var(--weight-semibold, 600);\n  color: var(--ink-accent, #ffcc6e);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wider, 0.1em);\n  margin: 0 0 var(--space-1, 0.25rem) 0;\n}\n\n.section-desc {\n  font-size: var(--text-sm, 0.75rem);\n  color: var(--ink-muted, #6b6b6e);\n  margin: 0;\n}\n\n/* Shop Grid */\n\n.shop-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n  gap: var(--spacing-lg);\n}\n\n/* Shop Item */\n\n.shop-item {\n  display: flex;\n  flex-direction: column;\n  background: rgba(0, 0, 0, 0.3);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius-md);\n  overflow: hidden;\n  transition: all 0.2s ease;\n}\n\n.shop-item:hover {\n  border-color: var(--border-primary);\n  transform: translateY(-2px);\n  box-shadow: var(--shadow-md);\n}\n\n.shop-item--disabled {\n  opacity: 0.6;\n}\n\n.shop-item--disabled:hover {\n  transform: none;\n  box-shadow: none;\n}\n\n/* Rarity borders */\n\n.sh