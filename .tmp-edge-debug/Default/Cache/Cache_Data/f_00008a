n  padding: 0 !important;\n  margin: 0 !important;\n}\n\n/* Add safe padding to all root containers */\n\n.basecamp-root,\n.roster-root,\n.shop-root,\n.crafting-root,\n.inventory-root,\n.opselect-root,\n.comms-array-root,\n.stable-root,\n.blackmarket-root,\n.opmap-root,\n.unitdetail-root,\n.gearworkbench-root,\n.battle-root,\n.settings-root,\n.quest-board-root,\n.recruitment-root,\n.tavern-root {\n  padding: 1rem 2rem !important;\n  box-sizing: border-box !important;\n  max-width: 100vw !important;\n  overflow-x: hidden !important;\n}\n\n/* Apply theme backgrounds to root containers */\n\n.basecamp-root:not([style*=\"background\"]),\n.roster-root:not([style*=\"background\"]),\n.shop-root:not([style*=\"background\"]),\n.crafting-root:not([style*=\"background\"]),\n.inventory-root:not([style*=\"background\"]),\n.opselect-root:not([style*=\"background\"]),\n.comms-array-root:not([style*=\"background\"]),\n.stable-root:not([style*=\"background\"]),\n.blackmarket-root:not([style*=\"background\"]),\n.opmap-root:not([style*=\"background\"]),\n.unitdetail-root:not([style*=\"background\"]),\n.gearworkbench-root:not([style*=\"background\"]),\n.settings-root:not([style*=\"background\"]),\n.quest-board-root:not([style*=\"background\"]),\n.recruitment-root:not([style*=\"background\"]),\n.tavern-root:not([style*=\"background\"]) {\n  background: var(--gradient-primary) !important;\n}\n\n/* Cards and containers should have margin from edges */\n\n.basecamp-card,\n.roster-card,\n.shop-card,\n.crafting-card,\n.inventory-card,\n.unitdetail-card,\n.settings-card,\n.recruitment-card,\n.tavern-card {\n  margin: 0 auto !important;\n  max-width: min(1200px, calc(100vw - 4rem)) !important;\n}\n\n/* ==========================================================================\n   BASE CAMP SCREEN - FULL WIDTH ARDYCIA\n   ========================================================================== */\n\n/* Resources Bar */\n\n.basecamp-resources {\n  width: 100% !important;\n  max-width: 1000px !