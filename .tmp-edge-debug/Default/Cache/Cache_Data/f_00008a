order-color: rgba(196, 152, 92, 0.42);\n}\n\n.recipe-item--selected {\n  border-color: var(--tech-amber, #ffcc6e);\n  box-shadow: 0 0 0 1px rgba(255, 204, 110, 0.16);\n}\n\n.recipe-item--disabled {\n  opacity: 0.58;\n}\n\n.recipe-item-name {\n  font-size: var(--text-sm, 0.78rem);\n  font-weight: var(--weight-semibold, 600);\n  color: var(--ink, #efe2cb);\n}\n\n.recipe-item-cost,\n.recipe-item-warning {\n  margin-top: var(--space-1, 0.3rem);\n  font-size: var(--text-xs, 0.58rem);\n}\n\n.recipe-item-cost {\n  color: var(--ink-muted, #c4a57a);\n}\n\n.recipe-item-warning {\n  color: #e18b73;\n}\n\n.crafting-details {\n  overflow-y: auto;\n}\n\n.detail-panel {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-3, 0.75rem);\n  min-height: 100%;\n}\n\n.detail-panel--empty {\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n}\n\n.detail-empty-icon {\n  font-size: 42px;\n  opacity: 0.38;\n}\n\n.detail-empty-text {\n  color: var(--ink-muted, #aa8b63);\n  font-size: var(--text-sm, 0.74rem);\n}\n\n.detail-header {\n  padding-bottom: var(--space-2, 0.5rem);\n  border-bottom: var(--stroke-1, 1px) solid rgba(168, 124, 69, 0.2);\n}\n\n.detail-title {\n  margin: 0 0 var(--space-1, 0.25rem);\n  color: var(--tech-amber, #ffcc6e);\n  font-size: var(--text-lg, 1rem);\n}\n\n.detail-category,\n.detail-label {\n  font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n  font-size: var(--text-xs, 0.58rem);\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: var(--ink-muted, #b69467);\n}\n\n.detail-description {\n  padding: var(--space-3, 0.7rem);\n  background: rgba(0, 0, 0, 0.18);\n  border: var(--stroke-1, 1px) solid rgba(168, 124, 69, 0.16);\n  border-radius: var(--radius-xs, 2px);\n  color: var(--ink-secondary, #e7d8bd);\n  line-height: 1.55;\n}\n\n.detail-requires-item,\n.cost-line,\n.output-item {\n  display: flex;\n  justify-content: space-between;\n  gap: var(--space-2, 0.4rem);\n  align-items: center;\n  padding: var(--space-2, 0.5rem) var(--space-3, 0.7rem);\n  background: var(--bg-surface, #2d261f);\n  border: var(--stroke-1, 1px) solid rgba(168, 124, 69, 0.18);\n  border-radius: var(--radius-xs, 2px);\n}\n\n.detail-requires-item--have,\n.cost-line--ok {\n  border-color: rgba(109, 180, 131, 0.35);\n}\n\n.detail-requires-item--missing,\n.cost-line--short {\n  border-color: rgba(209, 98, 72, 0.35);\n}\n\n.detail-actions {\n  margin-top: auto;\n}\n\n.craft-btn {\n  width: 100%;\n  padding: var(--space-3, 0.8rem) var(--space-4, 1rem);\n  background: linear-gradient(180deg, rgba(103, 79, 49, 0.98) 0%, rgba(63, 48, 29, 0.98) 100%);\n  border: var(--stroke-2, 2px) solid var(--tech-amber, #ffcc6e);\n  border-radius: var(--radius-sm, 3px);\n  color: var(--tech-amber, #ffcc6e);\n  font-size: var(--text-sm, 0.76rem);\n  font-weight: var(--weight-bold, 700);\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  cursor: pointer;\n  transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;\n}\n\n.craft-btn:hover:not(:disabled) {\n  transform: translateY(-1px);\n  box-shadow: 0 0 18px rgba(255, 204, 110, 0.22);\n}\n\n.craft-btn--disabled,\n.craft-btn:disabled {\n  cursor: not-allowed;\n  filter: grayscale(0.35);\n  opacity: 0.52;\n  box-shadow: none;\n}\n\n/* --------------------------------------------------------------------------\n   INVENTORY SELECTOR + LIBRARY CARD OVERRIDES\n   -------------------------------------------------------------------------- */\n\n.gear-selector-option {\n  flex-wrap: wrap;\n}\n\n.gear-option-badge {\n  margin-left: auto;\n  padding: 2px 6px;\n  border-radius: 999px;\n  background: rgba(140, 230, 255, 0.14);\n  border: 1px solid rgba(140, 230, 255, 0.28);\n  color: var(--tech-teal, #8ce6ff);\n  font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n  font-size: 0.48rem;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n}\n\n.library-card-list {\n  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));\n  gap: var(--space-3, 0.75rem);\n}\n\n.library-card {\n  display: flex;\n  justify-content: center;\n}\n\n.library-card .battle-cardui {\n  width: 188px;\n  height: 288px;\n}\n\n.library-card .battle-cardui:hover {\n  transform: translateY(-4px) scale(1.02);\n}\n\n.library-card--selected .battle-cardui {\n  border-color: #ffd700;\n  box-shadow:\n    0 0 0 3px rgba(255, 215, 0, 0.28),\n    0 12px 30px rgba(0, 0, 0, 0.52),\n    0 0 26px rgba(255, 215, 0, 0.2);\n}\n\n.library-card--dragging .battle-cardui {\n  opacity: 0.55;\n  transform: scale(0.96);\n}\n\n.library-card--common .battle-cardui {\n  border-color: #7f715b;\n}\n\n.library-card--uncommon .battle-cardui {\n  border-color: #58b66d;\n}\n\n.library-card--rare .battle-cardui {\n  border-color: #73b9d5;\n}\n\n.library-card--epic .battle-cardui,\n.library-card--legendary .battle-cardui {\n  border-color: #c9a66b;\n}\n\n.library-card .hs-card-desc {\n  padding: 10px 12px;\n  line-height: 1.45;\n}\n\n.library-card .hs-card-footer {\n  gap: 8px;\n}\n\n@media (max-width: 1200px) {\n  .crafting-tab-layout {\n    grid-template-columns: minmax(220px, 260px) minmax(0, 1fr);\n  }\n\n  .crafting-details {\n    grid-column: 1 / -1;\n  }\n}\n\n@media (max-width: 900px) {\n  .crafting-tab-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .resource-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n/* ===========================================================================\r\n   TAVERN SCREEN STYLES (Unified with Ardycia Design System)\r\n   =========================================================================== */\n\n/* Root container */\n\n.tavern-root {\r\n    position: fixed;\r\n    inset: 0;\r\n    z-index: 1000;\r\n    display: flex;\r\n    flex-direction: column;\r\n    background: var(--bg-world);\r\n    padding: var(--space-4);\r\n    font-family: var(--font-ui);\r\n    color: var(--ink);\r\n    overflow: hidden;\r\n}\n\n/* Header */\n\n.tavern-header {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    padding: var(--space-3) var(--space-4);\r\n    background: var(--bg-panel-alt);\r\n    border: var(--stroke-2) solid var(--stroke-panel);\r\n    border-radius: var(--radius-panel);\r\n    margin-bottom: var(--space-4);\r\n    box-shadow: var(--shadow-elev-1);\r\n}\n\n.tavern-title-group {\r\n    display: flex;\r\n    flex-direction: column;\r\n}\n\n.tavern-title {\r\n    font-size: var(--text-2xl);\r\n    font-weight: var(--weight-bold);\r\n    color: var(--ink-accent);\r\n    text-transform: uppercase;\r\n    letter-spacing: var(--tracking-wider);\r\n    margin: 0;\r\n}\n\n.tavern-subtitle {\r\n    font-size: var(--text-xs);\r\n    font-family: var(--font-terminal);\r\n    color: var(--ink-muted);\r\n    letter-spacing: var(--tracking-widest);\r\n}\n\n.tavern-controls {\r\n    display: flex;\r\n    gap: var(--space-4);\r\n    align-items: center;\r\n}\n\n.tavern-stats {\r\n    display: flex;\r\n    gap: var(--space-2);\r\n}\n\n.stat-badge {\r\n    padding: var(--space-1) var(--space-3);\r\n    background: var(--bg-surface);\r\n    border: var(--stroke-1) solid var(--accent-bronze);\r\n    border-radius: var(--radius-sm);\r\n    color: var(--ink-accent);\r\n    font-family: var(--font-terminal);\r\n    font-size: var(--text-xs);\r\n    font-weight: var(--weight-bold);\r\n}\n\n/* Body & Content Layout */\n\n.tavern-body {\r\n    flex: 1;\r\n    width: 100%;\r\n    display: flex;\r\n    flex-direction: column;\r\n    min-height: 0;\r\n    overflow: hidden;\r\n}\n\n.tavern-content-wrapper {\r\n    flex: 1;\r\n    display: grid;\r\n    grid-template-columns: 1fr 400px;\r\n    gap: var(--space-4);\r\n    min-height: 0;\r\n}\n\n.tavern-main-panel {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: var(--space-4);\r\n}\n\n/* Info Box & Flavor Text */\n\n.tavern-info-box {\r\n    background: var(--bg-panel);\r\n    border: var(--stroke-2) solid var(--stroke-panel);\r\n    border-radius: var(--radius-panel);\