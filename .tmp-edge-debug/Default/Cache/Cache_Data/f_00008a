(--weight-bold);\n  color: var(--ink-accent);\n}\n\n.ard-resource__label {\n  font-size: var(--text-xs);\n  color: var(--ink-muted);\n  text-transform: uppercase;\n}\n\n/* ==========================================================================\n   SECTION 11: STAT BARS & INDICATORS\n   ========================================================================== */\n\n/* Progress bar */\n\n.ard-bar {\n  position: relative;\n  height: 8px;\n  background: var(--bg-surface);\n  border: var(--stroke-1) solid var(--stroke-subtle);\n  border-radius: var(--radius-sm);\n  overflow: hidden;\n}\n\n.ard-bar__fill {\n  height: 100%;\n  background: var(--accent-bronze);\n  border-radius: inherit;\n  transition: width var(--transition-slow);\n}\n\n.ard-bar--hp .ard-bar__fill {\n  background: linear-gradient(90deg, var(--status-success) 0%, #6abb78 100%);\n}\n\n.ard-bar--hp.ard-bar--low .ard-bar__fill {\n  background: linear-gradient(90deg, var(--tech-red) 0%, #ff8866 100%);\n}\n\n.ard-bar--strain .ard-bar__fill {\n  background: linear-gradient(90deg, var(--tech-violet) 0%, var(--tech-violet-dim) 100%);\n}\n\n.ard-bar--exp .ard-bar__fill {\n  background: linear-gradient(90deg, var(--tech-amber) 0%, var(--tech-amber-dim) 100%);\n}\n\n/* Stat chip */\n\n.ard-stat-chip {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--space-1);\n  padding: var(--space-1) var(--space-2);\n  background: var(--bg-surface);\n  border: var(--stroke-1) solid var(--stroke-subtle);\n  border-radius: var(--radius-sm);\n  font-family: var(--font-terminal);\n  font-size: var(--text-xs);\n}\n\n.ard-stat-chip__label {\n  color: var(--ink-muted);\n  text-transform: uppercase;\n}\n\n.ard-stat-chip__value {\n  color: var(--ink);\n  font-weight: var(--weight-bold);\n}\n\n.ard-stat-chip--buff .ard-stat-chip__value {\n  color: var(--combat-buff);\n}\n\n.ard-stat-chip--debuff .ard-stat-chip__value {\n  color: var(--combat-debuff);\n}\n\n/* ==========================================================================\n   SECTION 12: CARD DISPLAY (Tactical Cards)\n   ========================================================================== */\n\n.ard-card {\n  position: relative;\n  width: 120px;\n  padding: var(--space-3);\n  background: var(--bg-panel);\n  border: var(--stroke-2) solid var(--stroke-panel);\n  border-radius: var(--radius-md);\n  box-shadow: var(--shadow-elev-1);\n  transition: all var(--transition-base);\n  cursor: pointer;\n}\n\n.ard-card:hover {\n  transform: translateY(-4px);\n  box-shadow: var(--shadow-elev-2);\n  border-color: var(--accent-bronze);\n}\n\n.ard-card--selected {\n  border-color: var(--tech-amber);\n  box-shadow: var(--shadow-glow-amber);\n}\n\n.ard-card__header {\n  margin-bottom: var(--space-2);\n}\n\n.ard-card__name {\n  font-size: var(--text-xs);\n  font-weight: var(--weight-semibold);\n  color: var(--ink);\n  margin: 0;\n  line-height: var(--leading-tight);\n}\n\n.ard-card__cost {\n  position: absolute;\n  top: var(--space-2);\n  right: var(--space-2);\n  width: 20px;\n  height: 20px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: var(--accent-bronze-dark);\n  border: var(--stroke-1) solid var(--accent-bronze);\n  border-radius: 50%;\n  font-family: var(--font-terminal);\n  font-size: var(--text-xs);\n  font-weight: var(--weight-bold);\n  color: var(--tech-amber);\n}\n\n.ard-card__body {\n  font-size: 10px;\n  color: var(--ink-muted);\n  line-height: var(--leading-normal);\n}\n\n/* Rarity indicators */\n\n.ard-card--common { border-left: 3px solid var(--rarity-common); }\n\n.ard-card--uncommon { border-left: 3px solid var(--rarity-uncommon); }\n\n.ard-card--rare { border-left: 3px solid var(--rarity-rare); }\n\n.ard-card--epic { border-left: 3px solid var(--rarity-epic); }\n\n.ard-card--legendary { border-left: 3px solid var(--rarity-legendary); }\n\n/* ==========================================================================\n   SECTION 13: ACCESSIBILITY & HIGH CONTRAST\n   ========================================================================== */\n\n@media (prefers-contrast: more) {\n  :root {\n    --ink: #ffffff;\n    --ink-secondary: #e0e0e0;\n    --ink-muted: #c0c0c0;\n    --stroke-panel: #a87c45;\n    --stroke-subtle: rgba(168, 124, 69, 0.5);\n  }\n\n  .ard-btn:focus-visible,\n  .ard-tab:focus-visible,\n  .ard-list-item:focus-visible {\n    outline-width: 3px;\n  }\n}\n\n/* Focus visible for keyboard navigation */\n\n:focus-visible {\n  outline: var(--stroke-2) solid var(--interactive-focus);\n  outline-offset: 2px;\n}\n\n/* Skip link for accessibility */\n\n.ard-skip-link {\n  position: absolute;\n  top: -100px;\n  left: var(--space-4);\n  padding: var(--space-3) var(--space-4);\n  background: var(--bg-terminal);\n  border: var(--stroke-2) solid var(--tech-crt);\n  color: var(--tech-crt);\n  z-index: 9999;\n  transition: top var(--transition-fast);\n}\n\n.ard-skip-link:focus {\n  top: var(--space-4);\n}\n\n/* ==========================================================================\n   SECTION 14: DEBUG WATERMARK (Dev builds only)\n   ========================================================================== */\n\n.ard-debug-watermark {\n  position: fixed;\n  bottom: var(--space-2);\n  left: var(--space-2);\n  padding: var(--space-1) var(--space-2);\n  background: rgba(0, 0, 0, 0.6);\n  border: var(--stroke-1) solid var(--tech-crt-dim);\n  border-radius: var(--radius-sm);\n  font-family: var(--font-terminal);\n  font-size: 9px;\n  color: var(--tech-crt);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide);\n  pointer-events: none;\n  z-index: 9999;\n  opacity: 0.7;\n}\n\n/* Screen-specific debug markers */\n\n.ard-debug-screen-marker {\n  position: fixed;\n  top: var(--space-2);\n  right: var(--space-2);\n  padding: var(--space-1) var(--space-3);\n  background: var(--bg-terminal);\n  border: var(--stroke-1) solid var(--tech-amber);\n  border-radius: var(--radius-sm);\n  font-family: var(--font-terminal);\n  font-size: 10px;\n  color: var(--tech-amber);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide);\n  pointer-events: none;\n  z-index: 9999;\n  opacity: 0.8;\n}\n\n/* CSS grid debug overlay */\n\n.ard-debug-grid {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  pointer-events: none;\n  z-index: 9998;\n  background:\n    repeating-linear-gradient(\n      0deg,\n      transparent,\n      transparent calc(var(--space-4) - 1px),\n      rgba(53, 255, 149, 0.1) calc(var(--space-4) - 1px),\n      rgba(53, 255, 149, 0.1) var(--space-4)\n    ),\n    repeating-linear-gradient(\n      90deg,\n      transparent,\n      transparent calc(var(--space-4) - 1px),\n      rgba(53, 255, 149, 0.1) calc(var(--space-4) - 1px),\n      rgba(53, 255, 149, 0.1) var(--space-4)\n    );\n}\n\n/* Token debug: show all CSS variables being used */\n\n.ard-debug-tokens * {\n  outline: 1px solid rgba(255, 0, 255, 0.3) !important;\n}\n\n/* ==========================================================================\n   STYLE GUIDE REFERENCE\n   ==========================================================================\n\n   ## Ardycia Design System v1.0\n\n   ### Color Usage:\n\n   WORLD PALETTE (Adventure Gothic):\n   - --world-moss, --world-bark, --world-walnut: Primary world backgrounds\n   - --world-iron, --world-steel: Structural/metal elements\n   - --world-parchment, --world-fog: Text and light accents\n   - --world-coal, --world-ash: Deep backgrounds\n\n   TECH PALETTE (S/COM_OS):\n   - --tech-crt: Terminal text, success states, health\n   - --tech-teal: Selected items, rare items, info states\n   - --tech-amber: Accents, headings, legendary items\n   - --tech-violet: Epic items, buffs, magic\n   - --tech-red: Errors, damage, danger\n\n   ACCENT METALS:\n   - --accent-bronze: Primary UI accent, panel borders\n   - --accent-oxide: Danger/error states\n   - --accent-steam: Tech/mechanical elements\n\n   ### Typography:\n\n   FONTS:\n   - --font-ui: Interface text (Inter/system)\n   - --font-terminal: Monospace for terminal, stats, labels\n   - --font-title: Headings (same as ui for now)\n\n   SIZES (rem-based):\n   - --text-xs (11px): Labels, badges\n   - --text-sm (12px): Body text, buttons\n   - --text-base (14px): Standard text\n   - --text-lg/xl/2xl/3xl: Headers\n\n   ### Component Patterns:\n\n   WORLD PANELS (.ard-panel):\n   - Bronze-bordered containers for game content\n   - Use --bg-panel or --bg-panel-alt backgrounds\n   - Add .ard-panel--inset for recessed panels\n\n   S/COM_OS (.slk-*):\n   - Terminal-style overlays with CRT green\n   - Use .slk-terminal-bar for header bars\n   - Add scanline effect with ::after pseudo-element\n\n   FFTA TABS (.ard-tab-bar):\n   - Horizontal tab bars for category selection\n   - Use --tech-amber for active state underline\n\n   ### Interactive States:\n\n   - idle: --interactive-idle (leather brown)\n   - hover: --interactive-hover (canvas beige)\n   - active: --interactive-active (bronze)\n   - focus: --interactive-focus (amber outline)\n   - disabled: --interactive-disabled (iron grey)\n\n   ### Spacing Scale:\n\n   - --space-1: 4px (tight padding)\n   - --space-2: 8px (element spacing)\n   - --space-3: 12px (standard padding)\n   - --space-4: 16px (section gaps)\n   - --space-6+: Large gaps, margins\n\n   ========================================================================== */\n\n/* ==========================================================================\n   CHAOS CORE - BATTLE SYSTEM STYLES\n   Ardycia Aesthetic: Utilitycore + S/COM_OS Terminal + FFTA Tactical\n\n   Uses tokens from ardycia-design-system.css (imported in styles.css)\n   ========================================================================== */\n\n/* --------------------------------------------------------------------------\n   CSS CUSTOM PROPERTIES - Battle-Specific Colors (extend design system)\n   -------------------------------------------------------------------------- */\n\n:root {\n  /* Base World Palette - Map to design system */\n  --ardycia-earth-dark: var(--world-coal, #1a1917);\n  --ardycia-earth-mid: var(--world-ash, #2d2c2a);\n  --ardycia-earth-light: var(--world-walnut, #4d3f34);\n  --ardycia-iron: var(--world-iron, #4a4a4d);\n  --ardycia-charcoal: var(--world-soot, #232220);\n\n  /* Autumn Warmth - Map to design system */\n  --ardycia-rust: var(--accent-oxide-light, #8a4242);\n  --ardycia-oxide: var(--accent-oxide, #6b2f2f);\n  --ardycia-amber: var(--tech-amber, #ffcc6e);\n  --ardycia-pumpkin: #b8612a;\n\n  /* S/COM_OS Tech Palette - Map to design system */\n  --slk-green: var(--tech-crt, #35ff95);\n  --slk-green-dim: var(--tech-crt-dim, #28cc78);\n  --slk-green-glow: var(--tech-crt-glow, rgba(53, 255, 149, 0.4));\n  --slk-teal: var(--tech-teal, #8ce6ff);\n  --slk-amber: var(--tech-amber, #ffcc6e);\n  --slk-violet: var(--tech-violet, #c0b3ff);\n  --slk-red: var(--tech-red, #ff6b5e);\n  --slk-red-dim: var(--tech-red-dim, #cc5548);\n\n  /* Metallic Accents - Map to design system */\n  --bronze: var(--accent-bronze, #a87c45);\n  --bronze-dark: var(--accent-bronze-dark, #7a5a32);\n  --bronze-light: var(--accent-bronze-light, #c9a066);\n  --steam-blue: var(--accent-steam, #4fa2ff);\n\n  /* UI Surfaces - Map to design system */\n  --surface-dark: var(--bg-terminal, rgba(10, 12, 15, 0.95));\n  --surface-mid: var(--bg-panel, #4d3f34);\n  --surface-light: var(--bg-elevated, #3a3937);\n  --surface-border: var(--stroke-subtle, rgba(168, 124, 69, 0.25));\n\n  /* Grid Colors - FFTA Inspired */\n  --tile-floor: var(--world-moss, #3d4a35);\n  --tile-floor-highlight: #4a5a45;\n  --tile-move: rgba(53, 255, 149, 0.25);\n  --tile-move-border: var(--tech-crt-glow, rgba(53, 255, 149, 0.6));\n  --tile-attack: rgba(255, 107, 94, 0.25);\n  --tile-attack-border: rgba(255, 107, 94, 0.6);\n  --tile-selected: var(--tech-amber-glow, rgba(255, 204, 110, 0.4));\n\n  /* Scanline Effect */\n  --scanline-opacity: var(--scanline-opacity, 0.04);\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE ROOT CONTAINER\n   -------------------------------------------------------------------------- */\n\n.battle-root {\n  min-height: 100vh;\n  background:\n    /* Subtle noise texture */\n    url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E\"),\n    /* Radial vignette */\n    radial-gradient(ellipse at center, var(--ardycia-earth-mid) 0%, var(--ardycia-earth-dark) 70%, #0d0b09 100%);\n  padding: var(--space-4, 1rem);\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-3, 0.75rem);\n  font-family: var(--font-terminal, 'JetBrains Mono', monospace);\n  color: var(--bronze-light);\n  position: relative;\n  overflow: hidden;\n}\n\n/* CRT Scanline Overlay */\n\n.battle-root::before {\n  content: '';\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: repeating-linear-gradient(0deg,\n      transparent,\n      transparent 2px,\n      rgba(0, 0, 0, var(--scanline-opacity)) 2px,\n      rgba(0, 0, 0, var(--scanline-opacity)) 4px);\n  pointer-events: none;\n  z-index: 1000;\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE CARD - Main Container\n   -------------------------------------------------------------------------- */\n\n.battle-card {\n  background: var(--surface-dark);\n  border: 1px solid var(--surface-border);\n  border-radius: 2px;\n  box-shadow:\n    0 0 20px rgba(0, 0, 0, 0.5),\n    inset 0 1px 0 rgba(168, 124, 69, 0.1);\n  overflow: hidden;\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE HEADER\n   -------------------------------------------------------------------------- */\n\n.battle-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  padding: 0.75rem 1rem;\n  background: linear-gradient(180deg, var(--ardycia-earth-mid) 0%, var(--ardycia-earth-dark) 100%);\n  border-bottom: 1px solid var(--surface-border);\n}\n\n.battle-header-left {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n}\n\n.battle-title {\n  font-size: 1rem;\n  font-weight: bold;\n  color: var(--slk-amber);\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  text-shadow: 0 0 10px rgba(255, 204, 110, 0.3);\n}\n\n.battle-subtitle {\n  font-size: 0.7rem;\n  color: var(--bronze);\n  letter-spacing: 0.05em;\n  opacity: 0.8;\n}\n\n.battle-header-right {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n}\n\n.battle-active-info {\n  text-align: right;\n}\n\n.battle-active-label {\n  font-size: 0.6rem;\n  color: var(--bronze);\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n}\n\n.battle-active-value {\n  font-size: 0.9rem;\n  color: var(--slk-teal);\n  font-weight: bold;\n  text-shadow: 0 0 8px rgba(140, 230, 255, 0.4);\n}\n\n.battle-back-btn {\n  padding: 0.4rem 0.8rem;\n  background: var(--ardycia-earth-light);\n  border: 1px solid var(--bronze-dark);\n  color: var(--bronze-light);\n  font-family: inherit;\n  font-size: 0.7rem;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.battle-back-btn:hover {\n  background: var(--bronze-dark);\n  color: var(--slk-amber);\n  border-color: var(--bronze);\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE GRID - FFTA Tactical Style\n   -------------------------------------------------------------------------- */\n\n.battle-body {\n  padding: 1rem;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  background:\n    radial-gradient(ellipse at center, rgba(45, 38, 31, 0.5) 0%, transparent 70%);\n  min-height: 300px;\n}\n\n.battle-grid-container {\n  position: relative;\n  /* Flat 2D grid for better precision */\n  transform-origin: center bottom;\n}\n\n.battle-grid {\n  display: grid;\n  grid-template-columns: repeat(var(--battle-grid-cols, 8), 1fr);\n  grid-template-rows: repeat(var(--battle-grid-rows, 6), 1fr);\n  gap: 2px;\n  background: rgba(0, 0, 0, 0.3);\n  padding: 3px;\n  border: 2px solid var(--bronze-dark);\n  border-radius: 2px;\n  box-shadow:\n    0 4px 20px rgba(0, 0, 0, 0.5),\n    inset 0 0 30px rgba(0, 0, 0, 0.3);\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE TILES - Tactical Grid Squares\n   -------------------------------------------------------------------------- */\n\n.battle-tile {\n  width: 64px;\n  height: 64px;\n  position: relative;\n  cursor: pointer;\n  overflow: hidden;\n  transition: all 0.15s ease;\n\n  /* Base tile appearance */\n  background:\n    linear-gradient(135deg, var(--tile-floor) 0%, var(--tile-floor-highlight) 50%, var(--tile-floor) 100%);\n  border: 1px solid rgba(168, 124, 69, 0.15);\n\n  /* Subtle inner shadow for depth */\n  box-shadow:\n    inset 0 1px 0 rgba(255, 255, 255, 0.05),\n    inset 0 -1px 0 rgba(0, 0, 0, 0.2);\n}\n\n.battle-tile:hover {\n  border-color: rgba(168, 124, 69, 0.4);\n  background:\n    linear-gradient(135deg, var(--tile-floor-highlight) 0%, #4a5a45 50%, var(--tile-floor-highlight) 100%);\n}\n\n/* Movement Option Tiles */\n\n.battle-tile--move-option {\n  background:\n    linear-gradient(135deg,\n      rgba(53, 255, 149, 0.15) 0%,\n      rgba(53, 255, 149, 0.25) 50%,\n      rgba(53, 255, 149, 0.15) 100%);\n  border-color: var(--tile-move-border);\n  animation: tile-pulse-move 1.5s ease-in-out infinite;\n}\n\n.battle-tile--move-option:hover {\n  background:\n    linear-gradient(135deg,\n      rgba(53, 255, 149, 0.25) 0%,\n      rgba(53, 255, 149, 0.4) 50%,\n      rgba(53, 255, 149, 0.25) 100%);\n  box-shadow:\n    0 0 15px var(--slk-green-glow),\n    inset 0 0 10px var(--slk-green-glow);\n}\n\n/* Attack Option Tiles */\n\n.battle-tile--attack-option {\n  background:\n    linear-gradient(135deg,\n      rgba(255, 107, 107, 0.15) 0%,\n      rgba(255, 107, 107, 0.25) 50%,\n      rgba(255, 107, 107, 0.15) 100%);\n  border-color: var(--tile-attack-border);\n  animation: tile-pulse-attack 1s ease-in-out infinite;\n}\n\n.battle-tile--attack-option:hover {\n  background:\n    linear-gradient(135deg,\n      rgba(255, 107, 107, 0.3) 0%,\n      rgba(255, 107, 107, 0.5) 50%,\n      rgba(255, 107, 107, 0.3) 100%);\n  box-shadow:\n    0 0 15px rgba(255, 107, 107, 0.4),\n    inset 0 0 10px rgba(255, 107, 107, 0.3);\n}\n\n/* Placement Option Tiles */\n\n.battle-tile--placement-option {\n  background:\n    linear-gradient(135deg,\n      rgba(255, 204, 110, 0.2) 0%,\n      rgba(255, 204, 110, 0.35) 50%,\n      rgba(255, 204, 110, 0.2) 100%);\n  border-color: var(--slk-amber);\n  animation: tile-pulse-facing 1s ease-in-out infinite;\n  box-shadow: inset 0 0 15px rgba(255, 204, 110, 0.2);\n}\n\n.battle-tile--placement-option:hover {\n  background:\n    linear-gradient(135deg,\n      rgba(255, 204, 110, 0.4) 0%,\n      rgba(255, 204, 110, 0.6) 50%,\n      rgba(255, 204, 110, 0.4) 100%);\n  box-shadow:\n    0 0 20px rgba(255, 204, 110, 0.5),\n    inset 0 0 15px rgba(255, 204, 110, 0.3);\n}\n\n/* Facing Option Tiles */\n\n.battle-tile--facing-option {\n  background:\n    linear-gradient(135deg,\n      rgba(255, 204, 110, 0.1) 0%,\n      rgba(255, 204, 110, 0.2) 50%,\n      rgba(255, 204, 110, 0.1) 100%);\n  border-color: var(--slk-amber);\n  animation: tile-pulse-facing 1s ease-in-out infinite;\n  cursor: pointer;\n  box-shadow: inset 0 0 10px rgba(255, 204, 110, 0.1);\n}\n\n.battle-tile--facing-option:hover {\n  background:\n    linear-gradient(135deg,\n      rgba(255, 204, 110, 0.25) 0%,\n      rgba(255, 204, 110, 0.4) 50%,\n      rgba(255, 204, 110, 0.25) 100%);\n  box-shadow:\n    0 0 12px rgba(255, 204, 110, 0.4),\n    inset 0 0 8px rgba(255, 204, 110, 0.2);\n}\n\n@keyframes tile-pulse-move {\n\n  0%,\n  100% {\n    opacity: 1;\n  }\n\n  50% {\n    opacity: 0.7;\n  }\n}\n\n@keyframes tile-pulse-attack {\n\n  0%,\n  100% {\n    opacity: 1;\n    border-color: var(--tile-attack-border);\n  }\n\n  50% {\n    opacity: 0.8;\n    border-color: var(--slk-red);\n  }\n}\n\n@keyframes tile-pulse-facing {\n\n  0%,\n  100% {\n    opacity: 1;\n    border-color: var(--slk-amber);\n  }\n\n  50% {\n    opacity: 0.8;\n    border-color: var(--bronze-light);\n  }\n}\n\n/* --------------------------------------------------------------------------\n   BATTLE UNITS - Character Tokens\n   -------------------------------------------------------------------------- */\n\n.battle-unit {\n  position: absolute;\n  top: 2px;\n  left: 2px;\n  right: 2px;\n  bottom: 2px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  border-radius: 4px;\n  padding: 4px;\n  transition: transform 0.3s ease-out;\n  z-index: 10;\n  background: rgba(8, 10, 12, 0.7);\n  border: 1px solid rgba(128, 109, 78, 0.35);\n}\n\n/* Unit Facing Indicator - Arrow showing direction */\n\n.battle-unit::before {\n  content: '';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 0;\n  height: 0;\n  border-left: 8px solid transparent;\n  border-right: 8px solid transparent;\n  border-bottom: 10px solid currentColor;\n  opacity: 0.9;\n  filter: drop-shadow(0 0 4px currentColor);\n  transition: all 0.2s ease;\n  z-index: 1001;\n  /* Above portrait */\n  pointer-events: none;\n}\n\n/* Facing directions - positioned ON the unit square relative to center */\n\n.battle-unit[data-facing=\"north\"]::before {\n  transform: translate(-50%, -32px) rotate(0deg);\n}\n\n.battle-unit[data-facing=\"south\"]::before {\n  transform: translate(-50%, 22px) rotate(180deg);\n}\n\n.battle-unit[data-facing=\"east\"]::before {\n  transform: translate(22px, -50%) rotate(90deg);\n  top: 50%;\n  left: 50%;\n}\n\n.battle-unit[data-facing=\"west\"]::before {\n  transform: translate(-38px, -50%) rotate(-90deg);\n  top: 50%;\n  left: 50%;\n}\n\n/* Ally Units */\n\n.battle-unit--ally {\n  background: linear-gradient(180deg, rgba(53, 255, 149, 0.1) 0%, rgba(26, 122, 72, 0.15) 100%);\n  border: 1px solid rgba(53, 255, 149, 0.45);\n  color: var(--slk-green);\n}\n\n.battle-unit--ally::before {\n  border-bottom-color: var(--slk-green);\n}\n\n/* Enemy Units */\n\n.battle-unit--enemy {\n  background: linear-gradient(180deg, rgba(255, 107, 107, 0.12) 0%, rgba(139, 58, 58, 0.16) 100%);\n  border: 1px solid rgba(255, 107, 107, 0.4);\n  color: var(--slk-red);\n}\n\n.battle-unit--enemy::before {\n  border-bottom-color: var(--slk-red);\n}\n\n/* Active Unit Highlight */\n\n.battle-unit--active {\n  z-index: 20;\n}\n\n.battle-unit--ally.battle-unit--active {\n  border-color: var(--slk-amber);\n}\n\n@keyframes unit-active-pulse {\n\n  0%,\n  100% {\n    transform: scale(1);\n  }\n\n  50% {\n    transform: scale(1.02);\n  }\n}\n\n/* Unit Info Display */\n\n.battle-unit-indicator {\n  display: none;\n  /* Hidden - using border colors instead */\n}\n\n.battle-unit-name {\n  font-size: 0.55rem;\n  font-weight: bold;\n  text-transform: uppercase;\n  letter-spacing: 0.03em;\n  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  max-width: 100%;\n  text-align: center;\n}\n\n.battle-unit-hp {\n  font-size: 0.5rem;\n  opacity: 0.9;\n  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);\n}\n\n.battle-unit-strain {\n  font-size: 0.45rem;\n  opacity: 0.7;\n  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);\n}\n\n/* --------------------------------------------------------------------------\n   S/COM_OS CONSOLE - Terminal Log\n   -------------------------------------------------------------------------- */\n\n.scrollink-console {\n  background: var(--ardycia-earth-dark);\n  border-top: 1px solid var(--surface-border);\n  font-family: 'Courier New', monospace;\n}\n\n.scrollink-console-header {\n  padding: 0.4rem 0.75rem;\n  background: linear-gradient(