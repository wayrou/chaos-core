er {\n  background: linear-gradient(135deg, #ffb833, var(--ard-gold));\n  transform: scale(1.02);\n  box-shadow: 0 4px 15px rgba(243, 163, 16, 0.4);\n}\n\n.class-change-btn:active {\n  transform: scale(0.98);\n}\n\n/* Mystery / Undiscovered Class Cards */\n\n.class-card--mystery {\n  background: linear-gradient(135deg,\n      rgba(37, 36, 36, 0.8),\n      rgba(45, 44, 44, 0.8));\n  border: 2px dashed rgba(243, 163, 16, 0.3);\n  opacity: 0.5;\n  min-height: 200px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  cursor: not-allowed;\n}\n\n.class-card--mystery:hover {\n  transform: none;\n  box-shadow: none;\n  opacity: 0.6;\n}\n\n.class-card--mystery .class-card-name {\n  font-size: 32px;\n  letter-spacing: 0.3em;\n  color: rgba(243, 163, 16, 0.5);\n  text-shadow: 0 0 20px rgba(243, 163, 16, 0.3);\n}\n\n.class-card--mystery .class-card-locked-badge {\n  background: linear-gradient(135deg,\n      rgba(88, 81, 80, 0.6),\n      rgba(77, 63, 52, 0.6));\n  color: rgba(243, 163, 16, 0.7);\n}\n\n.class-mystery-text {\n  font-size: 13px;\n  color: rgba(255, 255, 255, 0.4);\n  font-style: italic;\n  margin: 1rem 0;\n}\n\n.class-card-hint {\n  padding: 0.75rem 1rem;\n  background: rgba(243, 163, 16, 0.1);\n  border: 1px solid rgba(243, 163, 16, 0.2);\n  border-radius: 6px;\n  color: rgba(243, 163, 16, 0.8);\n  font-size: 12px;\n  font-weight: 600;\n  letter-spacing: 0.05em;\n  margin-top: 1rem;\n}\n\n.unitdetail-class-btn {\n  padding: 0.6rem 1.25rem;\n  margin-right: 1rem;\n  font-size: 13px;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  background: linear-gradient(135deg, #8b5cf6, #7c3aed);\n  border: none;\n  border-radius: 6px;\n  color: white;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.unitdetail-class-btn:hover {\n  background: linear-gradient(135deg, #a78bfa, #8b5cf6);\n  transform: scale(1.05);\n  box-shadow: 0 4px 12px rgba(139, 92, 246, 0.4);\n}\n\n.unitdetail-class-btn:active {\n  transform: scale(0.98);\n}\n\n/* ==========================================================================\n   FIELD SYSTEM STYLES\n   ========================================================================== */\n\n.field-root {\n  width: 100vw;\n  height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: #1a1a2e;\n  overflow: hidden;\n  position: relative;\n}\n\n.field-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--spacing-md) var(--spacing-lg);\n  background: rgba(10, 15, 30, 0.95);\n  border-bottom: 1px solid rgba(100, 120, 180, 0.3);\n  z-index: 100;\n  flex-shrink: 0;\n}\n\n.field-header-title {\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  color: var(--text-primary);\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n}\n\n.field-exit-btn {\n  padding: var(--spacing-sm) var(--spacing-lg);\n  background: var(--ard-brown-dark);\n  border: 1px solid var(--border-primary);\n  border-radius: var(--radius-md);\n  color: var(--text-primary);\n  font-family: var(--font-display);\n  font-size: var(--font-size-sm);\n  font-weight: 500;\n  cursor: pointer;\n  transition: all 0.2s ease;\n}\n\n.field-exit-btn:hover {\n  background: var(--ard-charcoal);\n  border-color: var(--ard-rust);\n}\n\n.field-viewport {\n  flex: 1;\n  position: relative;\n  overflow: hidden;\n  background: #0a0a1a;\n}\n\n.field-map {\n  position: relative;\n  background: #0f0f1f;\n}\n\n/* Tiles */\n\n.field-tile {\n  position: absolute;\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.field-tile-walkable {\n  background: rgba(40, 50, 70, 0.3);\n}\n\n.field-tile-wall {\n  background: rgba(20, 25, 40, 0.8);\n  border-color: rgba(100, 120, 180, 0.2);\n}\n\n.field-tile-floor {\n  background: rgba(50, 60, 80, 0.4);\n}\n\n.field-tile-grass {\n  background: rgba(30, 60, 40, 0.5);\n}\n\n.field-tile-dirt {\n  background: rgba(60, 50, 40, 0.5);\n}\n\n.field-tile-stone {\n  background: rgba(70, 70, 80, 0.6);\n}\n\n/* Objects (stations, resources, etc.) */\n\n.field-object {\n  position: absolute;\n  border: 2px solid rgba(140, 160, 255, 0.4);\n  background: rgba(20, 30, 50, 0.6);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: var(--radius-md);\n  z-index: 10;\n}\n\n.field-object-placeholder {\n  font-size: 10px;\n  color: var(--text-primary);\n  text-align: center;\n  padding: 4px;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n\n.field-object-station {\n  background: rgba(30, 40, 70, 0.7);\n  border-color: rgba(100, 150, 255, 0.5);\n}\n\n.field-object-resource {\n  background: rgba(50, 70, 40, 0.6);\n  border-color: rgba(100, 200, 100, 0.5);\n  border-radius: 50%;\n}\n\n/* Player Avatar */\n\n.field-player {\n  position: absolute;\n  z-index: 50;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  transition: transform 0.1s linear;\n}\n\n.field-player-sprite {\n  position: relative;\n  width: 100%;\n  height: 100%;\n  display: flex;\n  align-items: flex-end;\n  justify-content: center;\n  color: transparent;\n  font-size: 0;\n  text-shadow: none;\n  box-shadow: none;\n  overflow: visible;\n  pointer-events: none;\n}\n\n.field-player-sprite::before {\n  content: \"\";\n  position: absolute;\n  left: 50%;\n  bottom: -6%;\n  width: 220%;\n  height: 220%;\n  transform: translateX(-50%);\n  background: url(\"/src/assets/Placeholder_field.png\") center bottom / contain no-repeat;\n  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.35));\n}\n\n/* Interaction Prompt */\n\n.field-interaction-prompt {\n  position: absolute;\n  background: rgba(0, 0, 0, 0.9);\n  border: 2px solid var(--ard-gold);\n  border-radius: var(--radius-md);\n  padding: var(--spacing-sm) var(--spacing-lg);\n  color: var(--ard-gold);\n  font-family: var(--font-mono);\n  font-size: var(--font-size-md);\n  font-weight: 600;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  z-index: 200;\n  pointer-events: none;\n  box-shadow: 0 0 20px rgba(243, 163, 16, 0.5);\n  transform: translate(-50%, calc(-100% + 8px)) scale(0.96);\n  transform-origin: center bottom;\n  animation: pulse-glow 1.5s ease-in-out infinite;\n}\n\n@keyframes pulse-glow {\n\n  0%,\n  100% {\n    box-shadow: 0 0 20px rgba(243, 163, 16, 0.5);\n  }\n\n  50% {\n    box-shadow: 0 0 30px rgba(243, 163, 16, 0.8);\n  }\n}\n\n/* HUD */\n\n.field-hud {\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  padding: var(--spacing-md);\n  background: linear-gradient(180deg, transparent, rgba(10, 15, 30, 0.9));\n  z-index: 100;\n  pointer-events: none;\n}\n\n.field-hud-instructions {\n  font-size: var(--font-size-xs);\n  color: var(--text-muted);\n  text-align: center;\n  font-family: var(--font-mono);\n  letter-spacing: 0.1em;\n}\n\n/* ==========================================================================\n   QUEST BOARD SCREEN - ARDYCIA COLORS\n   ========================================================================== */\n\n.quest-board-root {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: var(--bg-world, #1a1917);\n  padding: var(--space-4, 1rem);\n  font-family: var(--font-ui, \"Inter\", sans-serif);\n  color: var(--ink, #e8e4dc);\n  overflow: hidden;\n}\n\n/* Header - Adventure Gothic Panel */\n\n.quest-board-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--space-3, 0.75rem) var(--space-4, 1rem);\n  background: var(--bg-panel-alt, #3b2f24);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  margin-bottom: var(--space-4, 1rem);\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n}\n\n.quest-board-header-left {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1, 0.25rem);\n}\n\n.quest-board-title {\n  font-size: var(--text-2xl, 1.5rem);\n  font-weight: var(--weight-bold, 700);\n  color: var(--ink-accent, #ffcc6e);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wider, 0.1em);\n  margin: 0;\n}\n\n.quest-board-subtitle {\n  font-size: var(--text-xs, 0.6875rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  color: var(--ink-muted, #6b6b6e);\n  letter-spacing: var(--tracking-widest, 0.15em);\n  text-transform: uppercase;\n}\n\n.quest-board-header-right {\n  display: flex;\n  align-items: center;\n  gap: var(--space-4, 1rem);\n}\n\n.quest-board-stats {\n  display: flex;\n  flex-direction: column;\n  align-items: flex-end;\n  padding: var(--space-2, 0.5rem) var(--space-4, 1rem);\n  background: var(--bg-surface, #2d2c2a);\n  border: var(--stroke-1, 1px) solid var(--accent-bronze, #a87c45);\n  border-radius: var(--radius-sm, 3px);\n}\n\n.stats-label {\n  font-size: var(--text-xs, 0.6875rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  color: var(--ink-muted, #6b6b6e);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide, 0.05em);\n}\n\n.stats-value {\n  font-size: var(--text-lg, 1.125rem);\n  font-weight: var(--weight-bold, 700);\n  color: var(--ink-accent, #ffcc6e);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n}\n\n.quest-board-back-btn {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2, 0.5rem);\n  padding: var(--space-2, 0.5rem) var(--space-4, 1rem);\n  background: var(--bg-surface, #2d2c2a);\n  border: var(--stroke-1, 1px) solid var(--stroke-subtle, rgba(168, 124, 69, 0.25));\n  border-radius: var(--radius-sm, 3px);\n  color: var(--ink-secondary, #a8a8a5);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  font-size: var(--text-xs, 0.6875rem);\n  font-weight: var(--weight-semibold, 600);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide, 0.05em);\n  cursor: pointer;\n  transition: all var(--transition-base, 0.15s ease);\n}\n\n.quest-board-back-btn:hover {\n  background: var(--interactive-hover, #6b5d4f);\n  border-color: var(--accent-bronze, #a87c45);\n  color: var(--ink, #e8e4dc);\n  transform: translateY(-1px);\n}\n\n.quest-board-back-btn:active {\n  transform: translateY(0);\n}\n\n/* Tabs - FFTA Style */\n\n.quest-board-tabs {\n  display: flex;\n  gap: var(--space-1, 0.25rem);\n  margin-bottom: var(--space-4, 1rem);\n  background: var(--bg-surface, #2d2c2a);\n  padding: var(--space-2, 0.5rem);\n  border-radius: var(--radius-md, 5px);\n}\n\n.quest-board-tab {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--space-2, 0.5rem);\n  padding: var(--space-2, 0.5rem) var(--space-4, 1rem);\n  background: transparent;\n  border: var(--stroke-1, 1px) solid transparent;\n  border-radius: var(--radius-sm, 3px);\n  color: var(--ink-muted, #6b6b6e);\n  font-family: var(--font-ui, \"Inter\", sans-serif);\n  font-size: var(--text-sm, 0.75rem);\n  font-weight: var(--weight-medium, 500);\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wide, 0.05em);\n  cursor: pointer;\n  transition: all var(--transition-base, 0.15s ease);\n  position: relative;\n}\n\n.quest-board-tab:hover {\n  background: var(--interactive-hover, #6b5d4f);\n  color: var(--ink, #e8e4dc);\n}\n\n.quest-board-tab--active {\n  background: var(--interactive-active, #a87c45);\n  border-color: var(--accent-bronze, #a87c45);\n  color: var(--ink-accent, #ffcc6e);\n  font-weight: var(--weight-semibold, 600);\n  box-shadow: 0 -2px 0 var(--tech-amber, #ffcc6e) inset;\n}\n\n.tab-badge {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 20px;\n  height: 20px;\n  padding: 0 6px;\n  background: var(--ink-accent, #ffcc6e);\n  color: var(--bg-world, #1a1917);\n  font-size: var(--text-xs, 0.6875rem);\n  font-weight: var(--weight-semibold, 600);\n  border-radius: 10px;\n  margin-left: var(--space-1, 0.25rem);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n}\n\n.tab-icon {\n  font-size: var(--text-base, 0.875rem);\n}\n\n/* Content - World Panel */\n\n.quest-board-content {\n  flex: 1;\n  background: var(--bg-panel, #4d3f34);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  padding: var(--space-4, 1rem);\n  overflow-y: auto;\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n}\n\n.quest-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-3, 0.75rem);\n}\n\n/* Quest Windows Container */\n\n.quest-board-windows {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: var(--space-4, 1rem);\n  width: 100%;\n}\n\n@media (max-width: 1200px) {\n  .quest-board-windows {\n    grid-template-columns: 1fr;\n  }\n}\n\n/* Individual Quest Window */\n\n.quest-window {\n  background: var(--bg-panel-alt, #3b2f24);\n  border: var(--stroke-2, 2px) solid var(--stroke-panel, #7a5a32);\n  border-radius: var(--radius-panel, 6px);\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  box-shadow: var(--shadow-elev-1, 0 2px 4px rgba(0, 0, 0, 0.5));\n}\n\n.quest-window--story {\n  border-left: 4px solid var(--ink-accent, #ffcc6e);\n}\n\n.quest-window--endless {\n  border-left: 4px solid var(--tech-crt, #35ff95);\n}\n\n.quest-window-header {\n  padding: var(--space-3, 0.75rem) var(--space-4, 1rem);\n  background: var(--bg-inset, rgba(0, 0, 0, 0.3));\n  border-bottom: var(--stroke-1, 1px) solid var(--stroke-panel, #7a5a32);\n  flex-shrink: 0;\n}\n\n.quest-window-title {\n  font-size: var(--text-lg, 1.125rem);\n  font-weight: var(--weight-semibold, 600);\n  color: var(--ink-accent, #ffcc6e);\n  margin: 0 0 var(--space-1, 0.25rem) 0;\n  text-transform: uppercase;\n  letter-spacing: var(--tracking-wider, 0.1em);\n}\n\n.quest-window-subtitle {\n  font-size: var(--text-xs, 0.6875rem);\n  color: var(--ink-muted, #6b6b6e);\n  font-family: var(--font-terminal, \"JetBrains Mono\", monospace);\n  letter-spacing: var(--tracking-wide, 0.05em);\n  text-transform: uppercase;\n}\n\n.quest-window-body {\n  fle